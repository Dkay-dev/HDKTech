@model HDKTech.Models.Category

@{
    ViewData["Title"] = $"Chi tiết: {Model?.Name}";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
}

<div class="p-3">

    <!-- ── Breadcrumb ──────────────────────────────────────────────── -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Category", new { area = "Admin" })" class="text-decoration-none">
                    <i class="fa-solid fa-tags me-1"></i>Danh mục
                </a>
            </li>
            <li class="breadcrumb-item active">@Model?.Name</li>
        </ol>
    </nav>

    <!-- ── Tiêu đề ──────────────────────────────────────────────────── -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <h5 class="fw-bold mb-0">
            <i class="fa-solid fa-folder-open text-danger me-2"></i>
            @Model?.Name
        </h5>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Edit", "Category", new { area = "Admin", id = Model?.Id })"
               class="btn btn-sm btn-primary">
                <i class="fa-solid fa-pen-to-square me-1"></i>Chỉnh sửa
            </a>
            <button type="button" id="deleteBtnDetail"
                    class="btn btn-sm btn-outline-danger"
                    data-id="@Model?.Id" data-name="@Model?.Name">
                <i class="fa-solid fa-trash me-1"></i>Xóa
            </button>
        </div>
    </div>

    <div class="row g-4">

        <!-- ── Cột trái ──────────────────────────────────────────── -->
        <div class="col-lg-8">

            <!-- Card: Thông tin cơ bản -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold border-bottom">
                    <i class="fa-solid fa-circle-info text-primary me-2"></i>Thông tin danh mục
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3 text-muted">Mã</dt>
                        <dd class="col-sm-9 fw-semibold">#@Model?.Id</dd>

                        <dt class="col-sm-3 text-muted">Tên danh mục</dt>
                        <dd class="col-sm-9 fw-bold text-danger">@Model?.Name</dd>

                        <dt class="col-sm-3 text-muted">Mô tả</dt>
                        <dd class="col-sm-9">@(Model?.Description ?? "Chưa có mô tả")</dd>

                        <dt class="col-sm-3 text-muted">Danh mục cha</dt>
                        <dd class="col-sm-9">
                            @if (Model?.ParentCategory != null)
                            {
                                <a href="@Url.Action("Details", "Category", new { area = "Admin", id = Model.ParentCategory.Id })"
                                   class="text-decoration-none">
                                    <i class="fa-solid fa-folder me-1"></i>@Model.ParentCategory.Name
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-success bg-opacity-75">Danh mục gốc</span>
                            }
                        </dd>
                    </dl>

                    @if (!string.IsNullOrEmpty(Model?.BannerImageUrl))
                    {
                        <div class="mt-3">
                            <dt class="text-muted small mb-2">Banner:</dt>
                            <img src="@Model.BannerImageUrl" alt="@Model.Name"
                                 class="img-fluid rounded border" style="max-height:200px; object-fit:cover;" />
                        </div>
                    }
                </div>
            </div>

            <!-- Card: Danh mục con -->
            @if (Model?.SubCategories?.Count > 0)
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white fw-semibold border-bottom d-flex align-items-center justify-content-between">
                        <span><i class="fa-solid fa-folder-tree text-warning me-2"></i>Danh mục con</span>
                        <span class="badge bg-warning text-dark">@Model.SubCategories.Count</span>
                    </div>
                    <div class="card-body">
                        <div class="row g-2">
                            @foreach (var sub in Model.SubCategories)
                            {
                                <div class="col-sm-6">
                                    <div class="border rounded p-3 d-flex align-items-center justify-content-between">
                                        <div>
                                            <div class="fw-semibold small">@sub.Name</div>
                                            <div class="text-muted" style="font-size:.75rem;">
                                                @(sub.Products?.Count ?? 0) sản phẩm
                                            </div>
                                        </div>
                                        <a href="@Url.Action("Details", "Category", new { area = "Admin", id = sub.Id })"
                                           class="btn btn-outline-secondary btn-sm">
                                            <i class="fa-solid fa-eye fa-xs"></i>
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Card: Sản phẩm -->
            @if (Model?.Products?.Count > 0)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-semibold border-bottom d-flex align-items-center justify-content-between">
                        <span><i class="fa-solid fa-box-open text-info me-2"></i>Sản phẩm trong danh mục</span>
                        <span class="badge bg-info text-dark">@Model.Products.Count</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover table-sm align-middle mb-0">
                            <thead class="table-light text-uppercase small text-muted">
                                <tr>
                                    <th>Tên sản phẩm</th>
                                    <th class="text-end">Giá</th>
                                    <th class="text-center">Kho</th>
                                    <th class="text-center" style="width:80px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Products.Take(10))
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (p.Images?.FirstOrDefault() != null)
                                                {
                                                    <img src="@p.Images.First().ImageUrl" alt="@p.Name"
                                                         class="rounded border" style="width:36px;height:36px;object-fit:cover;" />
                                                }
                                                else
                                                {
                                                    <span class="bg-light rounded d-inline-flex align-items-center justify-content-center"
                                                          style="width:36px;height:36px;">
                                                        <i class="fa-regular fa-image text-muted"></i>
                                                    </span>
                                                }
                                                <span class="small fw-semibold">@p.Name</span>
                                            </div>
                                        </td>
                                        <td class="text-end fw-bold text-danger small">
                                            @p.Price.ToString("N0") ₫
                                        </td>
                                        <td class="text-center">
                                            @{
                                                var qty = p.Inventories?.Sum(k => k.Quantity) ?? 0;
                                            }
                                            <span class="badge @(qty > 0 ? "bg-success bg-opacity-75" : "bg-danger bg-opacity-75")">
                                                @qty
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <a href="@Url.Action("Details", "Product", new { area = "Admin", id = p.Id })"
                                               class="btn btn-outline-secondary btn-sm py-0 px-2">
                                                <i class="fa-solid fa-eye fa-xs"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.Products.Count > 10)
                    {
                        <div class="card-footer bg-white text-center text-muted small border-top">
                            Đang hiển thị 10 / @Model.Products.Count sản phẩm
                        </div>
                    }
                </div>
            }

        </div>

        <!-- ── Cột phải: Thống kê + Actions ─────────────────────── -->
        <div class="col-lg-4">

            <!-- Card: Thống kê -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold border-bottom">
                    <i class="fa-solid fa-chart-bar text-secondary me-2"></i>Thống kê
                </div>
                <div class="card-body">
                    <div class="row g-3 text-center">
                        <div class="col-6">
                            <div class="bg-danger bg-opacity-10 rounded p-3">
                                <div class="fs-3 fw-bold text-danger">@(Model?.Products?.Count ?? 0)</div>
                                <div class="text-muted small">Sản phẩm</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-warning bg-opacity-10 rounded p-3">
                                <div class="fs-3 fw-bold text-warning">@(Model?.SubCategories?.Count ?? 0)</div>
                                <div class="text-muted small">DM con</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card: Hành động nhanh -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold border-bottom">
                    <i class="fa-solid fa-bolt text-warning me-2"></i>Hành động
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Edit", "Category", new { area = "Admin", id = Model?.Id })"
                           class="btn btn-primary btn-sm">
                            <i class="fa-solid fa-pen-to-square me-1"></i>Chỉnh sửa
                        </a>
                        <a href="@Url.Action("Create", "Category", new { area = "Admin" })"
                           class="btn btn-outline-success btn-sm">
                            <i class="fa-solid fa-plus me-1"></i>Tạo danh mục mới
                        </a>
                        <a href="@Url.Action("Index", "Category", new { area = "Admin" })"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="fa-solid fa-list me-1"></i>Danh sách
                        </a>
                        <hr class="my-1" />
                        <button type="button"
                                class="btn btn-outline-danger btn-sm"
                                id="deleteBtnDetail2"
                                data-id="@Model?.Id" data-name="@Model?.Name">
                            <i class="fa-solid fa-trash me-1"></i>Xóa danh mục
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ── Modal xác nhận xóa ──────────────────────────────────────── -->
<div class="modal fade" id="deleteModalDetail" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>Xác nhận xóa
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc muốn xóa danh mục <strong class="text-danger">"@Model?.Name"</strong>?</p>
                <p class="text-muted small mb-0">
                    <i class="fa-solid fa-triangle-exclamation me-1 text-warning"></i>
                    Không thể xóa nếu đang có sản phẩm hoặc danh mục con liên kết.
                </p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteDetailBtn">
                    <i class="fa-solid fa-trash me-1"></i>Xóa
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteModalDetail'));

        document.querySelectorAll('#deleteBtnDetail, #deleteBtnDetail2').forEach(btn => {
            btn.addEventListener('click', () => deleteModal.show());
        });

        document.getElementById('confirmDeleteDetailBtn').addEventListener('click', async function () {
            this.disabled = true;
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang xóa...';
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                const resp = await fetch('@Url.Action("Delete", "Category", new { area = "Admin" })', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ categoryId: '@Model?.Id', __RequestVerificationToken: token })
                });
                const data = await resp.json();
                deleteModal.hide();
                if (data.success) {
                    window.location.href = '@Url.Action("Index", "Category", new { area = "Admin" })';
                } else {
                    alert('⚠ ' + data.message);
                    this.disabled = false;
                    this.innerHTML = '<i class="fa-solid fa-trash me-1"></i>Xóa';
                }
            } catch {
                deleteModal.hide();
                alert('Lỗi kết nối. Vui lòng thử lại.');
                this.disabled = false;
                this.innerHTML = '<i class="fa-solid fa-trash me-1"></i>Xóa';
            }
        });
    </script>
    @Html.AntiForgeryToken()
}
