@{
    ViewData["Title"] = "Quản lý Danh Mục";

    var categories           = ViewBag.Categories as List<HDKTech.Models.Category> ?? new List<HDKTech.Models.Category>();
    var totalCount           = (int)(ViewBag.TotalCount ?? 0);
    var pageNumber           = (int)(ViewBag.PageNumber ?? 1);
    var pageSize             = (int)(ViewBag.PageSize ?? 20);
    var totalPages           = (int)(ViewBag.TotalPages ?? 1);
    var searchTerm           = (string)(ViewBag.SearchTerm ?? "");
    var totalCategories      = (int)(ViewBag.TotalCategories ?? 0);
    var totalProducts        = (int)(ViewBag.TotalProducts ?? 0);
    var categoriesNoProducts = (int)(ViewBag.CategoriesWithoutProducts ?? 0);
}

@section Styles {
    <!-- FontAwesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        .stat-card { border-left: 4px solid #dc3545; }
        .stat-card-warn { border-left: 4px solid #ffc107; }
        .stat-card-info { border-left: 4px solid #0dcaf0; }
        .btn-icon { width: 34px; height: 34px; padding: 0; display: inline-flex; align-items: center; justify-content: center; }
    </style>
}

<div class="p-3">

    <!-- ── Tiêu đề ────────────────────────────────────────────────────── -->
    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-0">
                <i class="fa-solid fa-tags text-danger me-2"></i>
                Quản lý <span class="text-danger">Danh Mục</span>
            </h4>
            <small class="text-muted">Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Export", "Category", new { area = "Admin", searchTerm })"
               class="btn btn-sm btn-outline-secondary">
                <i class="fa-solid fa-download me-1"></i> Xuất CSV
            </a>
            <a href="@Url.Action("Create", "Category", new { area = "Admin" })"
               class="btn btn-sm btn-danger">
                <i class="fa-solid fa-plus me-1"></i> Tạo danh mục
            </a>
        </div>
    </div>

    <!-- ── Thống kê ───────────────────────────────────────────────────── -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-4">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center gap-3">
                        <span class="fs-3 text-danger"><i class="fa-solid fa-folder-tree"></i></span>
                        <div>
                            <div class="text-muted small">Tổng danh mục</div>
                            <div class="fw-bold fs-4">@totalCategories</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card stat-card-info border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center gap-3">
                        <span class="fs-3 text-info"><i class="fa-solid fa-box-open"></i></span>
                        <div>
                            <div class="text-muted small">Tổng sản phẩm</div>
                            <div class="fw-bold fs-4">@totalProducts</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card stat-card-warn border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center gap-3">
                        <span class="fs-3 text-warning"><i class="fa-solid fa-triangle-exclamation"></i></span>
                        <div>
                            <div class="text-muted small">Danh mục trống</div>
                            <div class="fw-bold fs-4">@categoriesNoProducts</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Tìm kiếm ──────────────────────────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <form method="get" action="@Url.Action("Index", "Category", new { area = "Admin" })"
                  class="d-flex gap-2">
                <div class="input-group input-group-sm flex-grow-1">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fa-solid fa-magnifying-glass text-muted"></i>
                    </span>
                    <input type="text" name="searchTerm" value="@searchTerm"
                           placeholder="Tìm tên hoặc mô tả danh mục..."
                           class="form-control border-start-0" />
                </div>
                <button type="submit" class="btn btn-sm btn-danger px-3">
                    <i class="fa-solid fa-search me-1"></i> Tìm
                </button>
                @if (!string.IsNullOrWhiteSpace(searchTerm))
                {
                    <a href="@Url.Action("Index", "Category", new { area = "Admin" })"
                       class="btn btn-sm btn-outline-secondary">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                }
            </form>
        </div>
    </div>

    <!-- ── Bảng danh mục ─────────────────────────────────────────────── -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex align-items-center justify-content-between border-bottom">
            <span class="fw-semibold">Danh sách danh mục gốc</span>
            <span class="text-muted small">Tổng: <strong>@totalCount</strong></span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="table-light text-uppercase small text-muted">
                    <tr>
                        <th style="width:40px;">#</th>
                        <th>Tên Danh Mục</th>
                        <th>Mô Tả</th>
                        <th class="text-center" style="width:100px;">Sản Phẩm</th>
                        <th class="text-center" style="width:100px;">DM Con</th>
                        <th class="text-center" style="width:130px;">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (categories.Count > 0)
                    {
                        int rowIndex = (pageNumber - 1) * pageSize + 1;
                        @foreach (var cat in categories)
                        {
                            var productCount    = cat.Products?.Count ?? 0;
                            var subCount        = cat.SubCategories?.Count ?? 0;
                            <tr>
                                <td class="text-muted small">@rowIndex</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="bg-danger bg-opacity-10 text-danger rounded p-2">
                                            <i class="fa-solid fa-folder"></i>
                                        </span>
                                        <div>
                                            <a href="@Url.Action("Details", "Category", new { area = "Admin", id = cat.Id })"
                                               class="fw-semibold text-danger text-decoration-none link-hover">
                                                @cat.Name
                                            </a>
                                            <div class="text-muted small">ID: @cat.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <small class="text-muted">
                                        @(cat.Description?.Length > 60
                                            ? cat.Description.Substring(0, 60) + "…"
                                            : (cat.Description ?? "—"))
                                    </small>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(productCount > 0 ? "bg-info text-dark" : "bg-secondary bg-opacity-25 text-muted")">
                                        @productCount
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(subCount > 0 ? "bg-primary bg-opacity-75" : "bg-secondary bg-opacity-25 text-muted")">
                                        @subCount
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a href="@Url.Action("Details", "Category", new { area = "Admin", id = cat.Id })"
                                           class="btn btn-outline-secondary btn-icon" title="Chi tiết">
                                            <i class="fa-solid fa-eye fa-sm"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", "Category", new { area = "Admin", id = cat.Id })"
                                           class="btn btn-outline-primary btn-icon" title="Chỉnh sửa">
                                            <i class="fa-solid fa-pen-to-square fa-sm"></i>
                                        </a>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-icon btn-delete"
                                                data-id="@cat.Id"
                                                data-name="@cat.Name"
                                                title="Xóa">
                                            <i class="fa-solid fa-trash fa-sm"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            rowIndex++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fa-regular fa-folder-open fa-2x mb-2 d-block opacity-50"></i>
                                @if (!string.IsNullOrWhiteSpace(searchTerm))
                                {
                                    <span>Không tìm thấy danh mục nào với từ khóa "<strong>@searchTerm</strong>"</span>
                                }
                                else
                                {
                                    <span>Chưa có danh mục nào. <a href="@Url.Action("Create", "Category", new { area = "Admin" })">Tạo ngay!</a></span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Phân trang -->
        @if (totalPages > 1)
        {
            <div class="card-footer bg-white d-flex align-items-center justify-content-between flex-wrap gap-2 border-top">
                <small class="text-muted">
                    Hiển thị <strong>@((pageNumber - 1) * pageSize + 1)</strong>
                    – <strong>@Math.Min(pageNumber * pageSize, totalCount)</strong>
                    / <strong>@totalCount</strong>
                </small>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", "Category", new { area = "Admin", pageNumber = pageNumber - 1, searchTerm })">
                                <i class="fa-solid fa-chevron-left fa-xs"></i>
                            </a>
                        </li>
                        @for (int i = Math.Max(1, pageNumber - 2); i <= Math.Min(totalPages, pageNumber + 2); i++)
                        {
                            <li class="page-item @(i == pageNumber ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", "Category", new { area = "Admin", pageNumber = i, searchTerm })">@i</a>
                            </li>
                        }
                        <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", "Category", new { area = "Admin", pageNumber = pageNumber + 1, searchTerm })">
                                <i class="fa-solid fa-chevron-right fa-xs"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- ── Modal xác nhận xóa ──────────────────────────────────────────────── -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>Xác nhận xóa
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Bạn có chắc muốn xóa danh mục:</p>
                <p class="fw-bold text-danger" id="deleteCategoryName"></p>
                <p class="text-muted small mb-0">
                    <i class="fa-solid fa-triangle-exclamation me-1"></i>
                    Lưu ý: Không thể xóa nếu danh mục đang có sản phẩm hoặc danh mục con.
                </p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="fa-solid fa-xmark me-1"></i> Hủy
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa-solid fa-trash me-1"></i> Xóa
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Xóa danh mục qua AJAX ────────────────────────────────────────────
    let pendingDeleteId = null;
    const deleteModal   = new bootstrap.Modal(document.getElementById('deleteModal'));

    document.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', function () {
            pendingDeleteId = this.dataset.id;
            document.getElementById('deleteCategoryName').textContent = '"' + this.dataset.name + '"';
            deleteModal.show();
        });
    });

    document.getElementById('confirmDeleteBtn').addEventListener('click', async function () {
        if (!pendingDeleteId) return;
        this.disabled = true;
        this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xóa...';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const response = await fetch('@Url.Action("Delete", "Category", new { area = "Admin" })', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ categoryId: pendingDeleteId, __RequestVerificationToken: token })
            });
            const data = await response.json();

            deleteModal.hide();
            showToast(data.success ? 'success' : 'danger', data.message);
            if (data.success) setTimeout(() => location.reload(), 1200);
        } catch (err) {
            deleteModal.hide();
            showToast('danger', 'Lỗi kết nối. Vui lòng thử lại.');
        } finally {
            this.disabled = false;
            this.innerHTML = '<i class="fa-solid fa-trash me-1"></i> Xóa';
        }
    });

    // ── Toast thông báo Bootstrap 5 ──────────────────────────────────────
    function showToast(type, message) {
        const toastEl = document.createElement('div');
        toastEl.className = `toast align-items-center text-bg-${type} border-0 show`;
        toastEl.setAttribute('role', 'alert');
        toastEl.style.cssText = 'min-width:280px;';
        toastEl.innerHTML = `
            <div class="d-flex">
                <div class="toast-body fw-semibold">
                    <i class="fa-solid ${type === 'success' ? 'fa-circle-check' : 'fa-circle-xmark'} me-2"></i>
                    ${message}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>`;
        let container = document.getElementById('toast-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'toast-container';
            container.style.cssText = 'position:fixed;top:1rem;right:1rem;z-index:9999;display:flex;flex-direction:column;gap:.5rem;';
            document.body.appendChild(container);
        }
        container.appendChild(toastEl);
        setTimeout(() => toastEl.remove(), 4000);
    }
</script>
@Html.AntiForgeryToken()
}
