@model HDKTech.Areas.Admin.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    // Chuỗi JSON cho Chart.js - serialize dữ liệu thực từ ViewModel
    var chartLabels   = System.Text.Json.JsonSerializer.Serialize(Model.DailyRevenue.Select(d => d.DayName).ToList());
    var chartRevenues = System.Text.Json.JsonSerializer.Serialize(Model.DailyRevenue.Select(d => (double)d.Revenue).ToList());
}

@section Styles {
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <style>
        .stat-card { transition: transform .2s, box-shadow .2s; }
        .stat-card:hover { transform: translateY(-3px); box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.15) !important; }
        .stat-icon { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 12px; }
        .badge-status { font-size: .78rem; padding: .35em .7em; border-radius: .5rem; }
        .audit-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    </style>
}

<!-- ════════════════════════════════════════════════════════ -->
<!--  HEADER ROW                                              -->
<!-- ════════════════════════════════════════════════════════ -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</h4>
        <small class="text-muted">Cập nhật lần cuối: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
    </div>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-primary btn-sm">
        <i class="bi bi-receipt me-1"></i> Xem đơn hàng
    </a>
</div>

<!-- ════════════════════════════════════════════════════════ -->
<!--  STATS CARDS ROW (Bootstrap 5 Grid)                      -->
<!-- ════════════════════════════════════════════════════════ -->
<div class="row g-3 mb-4">

    <!-- Doanh thu -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-cash-coin fs-4"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="text-muted small mb-1">Tổng doanh thu</div>
                    <div class="fw-bold fs-5 text-success">@Model.TotalRevenue.ToString("N0") ₫</div>
                    <div class="text-muted" style="font-size:.75rem">Đơn đã giao thành công</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tổng đơn hàng -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-bag-check fs-4"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="text-muted small mb-1">Tổng đơn hàng</div>
                    <div class="fw-bold fs-5">@Model.TotalOrders.ToString("N0")</div>
                    <div class="text-warning" style="font-size:.75rem">
                        <i class="bi bi-clock me-1"></i>@Model.PendingOrders đơn chờ xử lý
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Banner -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-image fs-4"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="text-muted small mb-1">Banner</div>
                    <div class="fw-bold fs-5">@Model.TotalBanners</div>
                    <div class="text-success" style="font-size:.75rem">
                        <i class="bi bi-check-circle me-1"></i>@Model.ActiveBanners đang hiển thị
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tồn kho thấp -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-exclamation-triangle fs-4"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="text-muted small mb-1">Hàng sắp hết</div>
                    <div class="fw-bold fs-5 text-danger">@Model.LowStockCount sản phẩm</div>
                    <div class="text-muted" style="font-size:.75rem">Tồn kho dưới 10 chiếc</div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ════════════════════════════════════════════════════════ -->
<!--  ROW 2: BIỂU ĐỒ + KHÁCH HÀNG / KHUYẾN MÃI             -->
<!-- ════════════════════════════════════════════════════════ -->
<div class="row g-3 mb-4">

    <!-- Chart.js - Doanh thu 7 ngày -->
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 d-flex align-items-center justify-content-between pt-3 pb-0">
                <div>
                    <h6 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Doanh thu 7 ngày gần nhất</h6>
                    <small class="text-muted">Chỉ tính đơn hàng đã giao thành công (Status = 3)</small>
                </div>
            </div>
            <div class="card-body">
                <!-- Khu vực Chart.js - CDN đã load ở section Styles -->
                <canvas id="revenueChart" style="max-height:260px"></canvas>
            </div>
        </div>
    </div>

    <!-- Tóm tắt nhanh -->
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-lightning-charge me-2 text-warning"></i>Tóm tắt nhanh</h6>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="bi bi-person-plus me-2 text-primary"></i>Khách hàng mới (30 ngày)</span>
                        <span class="badge bg-primary rounded-pill">@Model.NewCustomers</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="bi bi-percent me-2 text-success"></i>Khuyến mãi đang chạy</span>
                        <span class="badge bg-success rounded-pill">@Model.ActivePromotions</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="bi bi-clock-history me-2 text-warning"></i>Đơn chờ xử lý</span>
                        <span class="badge bg-warning text-dark rounded-pill">@Model.PendingOrders</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="bi bi-box-seam me-2 text-danger"></i>Tồn kho cảnh báo</span>
                        <span class="badge bg-danger rounded-pill">@Model.LowStockCount</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span><i class="bi bi-image me-2 text-info"></i>Banner đang hiển thị</span>
                        <span class="badge bg-info rounded-pill">@Model.ActiveBanners</span>
                    </li>
                </ul>
                <div class="mt-3 d-grid gap-2">
                    <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="btn btn-outline-info btn-sm">
                        <i class="bi bi-image me-1"></i> Quản lý Banner
                    </a>
                    <a asp-area="Admin" asp-controller="Promotion" asp-action="Index" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-percent me-1"></i> Khuyến mãi
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ════════════════════════════════════════════════════════ -->
<!--  ROW 3: ĐƠN HÀNG GẦN ĐÂY + AUDIT LOG                  -->
<!-- ════════════════════════════════════════════════════════ -->
<div class="row g-3">

    <!-- Bảng 5 đơn hàng gần nhất -->
    <div class="col-12 col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex align-items-center justify-content-between pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-receipt me-2 text-primary"></i>Đơn hàng gần đây</h6>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-outline-primary btn-sm">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Ngày đặt</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-3">Tổng tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                Func<int, (string, string)> GetOrderStatusStyle = (status) => status switch
                                {
                                    0 => ("bg-secondary", "Chờ xác nhận"),
                                    1 => ("bg-warning text-dark", "Đã xác nhận"),
                                    2 => ("bg-info text-dark", "Đang giao"),
                                    3 => ("bg-success", "Đã giao"),
                                    4 => ("bg-danger", "Đã huỷ"),
                                    _ => ("bg-light text-dark", "N/A")
                                };
                            }
                            @if (Model.RecentOrders.Any())
                            {
                                @foreach (var order in Model.RecentOrders)
                                {
                                    var (badgeClass, statusText) = GetOrderStatusStyle(order.Status);
                                    <tr>
                                        <td class="ps-3">
                                            <span class="fw-semibold text-primary">#@order.OrderCode</span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold"
                                                     style="width:32px;height:32px;font-size:.75rem">
                                                    @((order.User?.FullName ?? order.User?.Email ?? "?")[0])
                                                </div>
                                                <div>
                                                    <div class="small fw-semibold">@(order.User?.FullName ?? order.User?.Email ?? "Khách vãng lai")</div>
                                                    <div class="text-muted" style="font-size:.7rem">@order.User?.Email</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><small class="text-muted">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</small></td>
                                        <td>
                                            <span class="badge badge-status @badgeClass">@statusText</span>
                                        </td>
                                        <td class="text-end pe-3 fw-semibold">@order.TotalAmount.ToString("N0") ₫</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>Chưa có đơn hàng nào
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- 5 Audit Log gần nhất -->
    <div class="col-12 col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 d-flex align-items-center justify-content-between pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-journal-text me-2 text-secondary"></i>Hoạt động gần đây</h6>
                <a asp-area="Admin" asp-controller="SystemLog" asp-action="Index" class="btn btn-outline-secondary btn-sm">Xem log</a>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @{
                        Func<string, (string, string)> GetAuditLogStyle = (action) => action switch
                        {
                            "Create" => ("bg-success", "bi-plus-circle text-success"),
                            "Update" => ("bg-warning", "bi-pencil-square text-warning"),
                            "Delete" => ("bg-danger", "bi-trash text-danger"),
                            "Login"  => ("bg-primary", "bi-box-arrow-in-right text-primary"),
                            "Logout" => ("bg-secondary", "bi-box-arrow-right text-secondary"),
                            _        => ("bg-info", "bi-info-circle text-info")
                        };
                    }
                    @if (Model.RecentAuditLogs.Any())
                    {
                        @foreach (var log in Model.RecentAuditLogs)
                        {
                            var (dotColor, iconClass) = GetAuditLogStyle(log.Action);
                            <li class="list-group-item px-3 py-2">
                                <div class="d-flex align-items-start gap-2">
                                    <span class="audit-dot @dotColor mt-2 flex-shrink-0"></span>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="fw-semibold small text-truncate" style="max-width:140px" title="@log.Username">
                                                @log.Username
                                            </span>
                                            <span class="text-muted" style="font-size:.68rem;white-space:nowrap">
                                                @log.Timestamp.ToString("HH:mm dd/MM")
                                            </span>
                                        </div>
                                        <div class="small text-muted text-truncate" title="@log.Description">
                                            <span class="badge bg-light text-dark me-1 border">@log.Action</span>@log.Description
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-center text-muted py-4">
                            <i class="bi bi-journal-x fs-4 d-block mb-2"></i>Chưa có hoạt động nào
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    // ── Chart.js: Biểu đồ doanh thu 7 ngày ─────────────────────────────────
    (function () {
        const labels   = @Html.Raw(chartLabels);
        const revenues = @Html.Raw(chartRevenues);

        const ctx = document.getElementById('revenueChart');
        if (!ctx) return;

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu (₫)',
                    data: revenues,
                    backgroundColor: revenues.map((v, i) =>
                        i === revenues.length - 1
                            ? 'rgba(13,110,253,0.85)'   // hôm nay - màu đậm
                            : 'rgba(13,110,253,0.35)'
                    ),
                    borderColor: 'rgba(13,110,253,1)',
                    borderWidth: 1.5,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => {
                                const val = ctx.parsed.y;
                                return ' ' + new Intl.NumberFormat('vi-VN', {
                                    style: 'currency', currency: 'VND'
                                }).format(val);
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: val => new Intl.NumberFormat('vi-VN', {
                                notation: 'compact', compactDisplay: 'short'
                            }).format(val) + ' ₫'
                        }
                    }
                }
            }
        });
    })();
</script>
}
