@{
    ViewData["Title"] = "Xuất Báo Cáo";
}

<div class="container-fluid py-4">

    @* ── Breadcrumb ───────────────────────────────────────────────── *@
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Xuất Báo Cáo</li>
        </ol>
    </nav>

    @* ── Page Header ──────────────────────────────────────────────── *@
    <div class="d-flex align-items-center gap-2 mb-4">
        <div class="bg-success bg-opacity-10 rounded-3 p-2">
            <i class="bi bi-file-earmark-spreadsheet text-success fs-4"></i>
        </div>
        <div>
            <h4 class="mb-0 fw-semibold">Xuất Báo Cáo Excel</h4>
            <small class="text-muted">Tải báo cáo doanh thu và tồn kho về máy</small>
        </div>
    </div>

    @* ── Alert ────────────────────────────────────────────────────── *@
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        @* ═══════════════════════════════════════════════════════════ *@
        @* CARD 1: Báo Cáo Doanh Thu                                  *@
        @* ═══════════════════════════════════════════════════════════ *@
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-primary text-white d-flex align-items-center gap-2 py-3">
                    <i class="bi bi-graph-up-arrow fs-5"></i>
                    <span class="fw-semibold">Báo Cáo Doanh Thu</span>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-3">
                        Xuất danh sách các đơn hàng <strong>đã giao thành công</strong> theo
                        khoảng thời gian tùy chọn. File Excel bao gồm: Mã đơn, Khách hàng,
                        Ngày thanh toán, Tổng tiền, Giảm giá.
                    </p>

                    <form method="get"
                          asp-area="Admin" asp-controller="Reports" asp-action="ExportRevenue"
                          id="revenueForm">

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <label for="start" class="form-label fw-medium">
                                    <i class="bi bi-calendar-event me-1 text-primary"></i>Từ ngày
                                </label>
                                <input type="date"
                                       id="start" name="start"
                                       class="form-control"
                                       value="@ViewBag.StartDate"
                                       max="@DateTime.Now.ToString("yyyy-MM-dd")"
                                       required />
                            </div>
                            <div class="col-sm-6">
                                <label for="end" class="form-label fw-medium">
                                    <i class="bi bi-calendar-check me-1 text-primary"></i>Đến ngày
                                </label>
                                <input type="date"
                                       id="end" name="end"
                                       class="form-control"
                                       value="@ViewBag.EndDate"
                                       max="@DateTime.Now.ToString("yyyy-MM-dd")"
                                       required />
                            </div>
                        </div>

                        @* Quick-select shortcuts *@
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            <button type="button" class="btn btn-outline-secondary btn-sm quick-range"
                                    data-days="7">7 ngày qua</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm quick-range"
                                    data-days="30">30 ngày qua</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    id="thisMonth">Tháng này</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    id="lastMonth">Tháng trước</button>
                        </div>

                        <button type="submit" class="btn btn-primary w-100" id="revenueBtn">
                            <i class="bi bi-download me-2"></i>Tải Báo Cáo Doanh Thu
                        </button>
                    </form>
                </div>
                <div class="card-footer bg-light text-muted small py-2 px-4">
                    <i class="bi bi-info-circle me-1"></i>
                    Định dạng: <strong>.xlsx</strong> — tương thích Microsoft Excel, Google Sheets, LibreOffice
                </div>
            </div>
        </div>

        @* ═══════════════════════════════════════════════════════════ *@
        @* CARD 2: Báo Cáo Tồn Kho                                    *@
        @* ═══════════════════════════════════════════════════════════ *@
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-success text-white d-flex align-items-center gap-2 py-3">
                    <i class="bi bi-boxes fs-5"></i>
                    <span class="fw-semibold">Báo Cáo Tồn Kho</span>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-3">
                        Xuất toàn bộ danh sách sản phẩm kèm thông tin tồn kho hiện tại.
                        File Excel bao gồm: Tên sản phẩm, Danh mục, Giá nhập, Giá bán, Số lượng tồn.
                        <br />
                        <span class="text-danger fw-medium">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Các sản phẩm tồn kho dưới 5 được đánh dấu màu đỏ.
                        </span>
                    </p>

                    <div class="alert alert-warning border-0 py-2 px-3 mb-4" role="alert">
                        <i class="bi bi-clock-history me-1"></i>
                        Dữ liệu phản ánh trạng thái tồn kho <strong>tại thời điểm xuất file</strong>.
                    </div>

                    <a asp-area="Admin" asp-controller="Reports" asp-action="ExportInventory"
                       class="btn btn-success w-100" id="inventoryBtn">
                        <i class="bi bi-download me-2"></i>Tải Báo Cáo Tồn Kho
                    </a>
                </div>
                <div class="card-footer bg-light text-muted small py-2 px-4">
                    <i class="bi bi-info-circle me-1"></i>
                    Định dạng: <strong>.xlsx</strong> — tương thích Microsoft Excel, Google Sheets, LibreOffice
                </div>
            </div>
        </div>

    </div>@* /.row *@

</div>@* /.container-fluid *@

@section Scripts {
<script>
    // ── Quick-range shortcuts ──────────────────────────────────────────────
    const today = new Date();

    function fmt(d) {
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${y}-${m}-${day}`;
    }

    document.querySelectorAll('.quick-range').forEach(btn => {
        btn.addEventListener('click', () => {
            const days = parseInt(btn.dataset.days);
            const from = new Date(today);
            from.setDate(from.getDate() - days + 1);
            document.getElementById('start').value = fmt(from);
            document.getElementById('end').value   = fmt(today);
        });
    });

    document.getElementById('thisMonth')?.addEventListener('click', () => {
        const first = new Date(today.getFullYear(), today.getMonth(), 1);
        document.getElementById('start').value = fmt(first);
        document.getElementById('end').value   = fmt(today);
    });

    document.getElementById('lastMonth')?.addEventListener('click', () => {
        const first = new Date(today.getFullYear(), today.getMonth() - 1, 1);
        const last  = new Date(today.getFullYear(), today.getMonth(), 0);
        document.getElementById('start').value = fmt(first);
        document.getElementById('end').value   = fmt(last);
    });

    // ── Validate: start <= end ──────────────────────────────────────────
    document.getElementById('revenueForm')?.addEventListener('submit', function (e) {
        const s  = document.getElementById('start').value;
        const en = document.getElementById('end').value;
        if (s && en && s > en) {
            e.preventDefault();
            alert('Ngày bắt đầu không thể lớn hơn ngày kết thúc!');
        }
    });

    // ── Loading indicator ──────────────────────────────────────────────
    document.getElementById('revenueBtn')?.addEventListener('click', function () {
        const btn = this;
        setTimeout(() => {
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang tạo file...';
            btn.disabled = true;
            setTimeout(() => {
                btn.innerHTML = '<i class="bi bi-download me-2"></i>Tải Báo Cáo Doanh Thu';
                btn.disabled = false;
            }, 5000);
        }, 0);
    });

    document.getElementById('inventoryBtn')?.addEventListener('click', function () {
        const btn = this;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang tạo file...';
        btn.classList.add('disabled');
        setTimeout(() => {
            btn.innerHTML = '<i class="bi bi-download me-2"></i>Tải Báo Cáo Tồn Kho';
            btn.classList.remove('disabled');
        }, 5000);
    });
</script>
}
