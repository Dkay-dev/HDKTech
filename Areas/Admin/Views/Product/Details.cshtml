@using HDKTech.Models
@model Product

@{
    ViewData["Title"] = Model?.Id > 0 ? "Chỉnh sửa sản phẩm" : "Tạo sản phẩm mới";
    var isEdit = Model?.Id > 0;
}

<style>
    .product-form-header {
        background: linear-gradient(135deg, #f6f3f2 0%, #fcf9f8 100%);
        border-bottom: 2px solid #ff2222;
    }

    .form-section-title {
        color: #1a1a1a;
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 12px;
        padding-bottom: 16px;
        border-bottom: 3px solid #ff2222;
        margin-bottom: 24px;
    }

    .form-section-title span {
        color: #ff2222;
        font-size: 20px;
    }

    .form-input {
        background-color: #ffffff;
        border: 1.5px solid #dddddd;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .form-input:focus {
        border-color: #ff2222;
        box-shadow: 0 0 0 3px rgba(255, 34, 34, 0.1);
        outline: none;
    }

    .form-input::placeholder {
        color: #999999;
    }

    .form-label {
        font-weight: 600;
        color: #333333;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .form-label .required {
        color: #ff2222;
        font-weight: 900;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .image-upload-area {
        border: 2px dashed #dddddd;
        border-radius: 8px;
        padding: 32px;
        text-align: center;
        transition: all 0.3s ease;
        background-color: #fafafa;
    }

    .image-upload-area:hover {
        border-color: #ff2222;
        background-color: rgba(255, 34, 34, 0.02);
    }

    .image-preview {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 12px;
        margin-top: 16px;
    }

    .image-preview-item {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 1;
        background-color: #f5f5f5;
        border: 1px solid #dddddd;
    }

    .image-preview-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .remove-image-btn {
        position: absolute;
        top: 4px;
        right: 4px;
        background: #ff2222;
        color: white;
        border: none;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .image-preview-item:hover .remove-image-btn {
        opacity: 1;
    }

    .alert-custom {
        border-radius: 8px;
        border-left: 4px solid;
        padding: 16px;
        margin-bottom: 20px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

    .alert-success-custom {
        background-color: rgba(40, 167, 69, 0.1);
        border-color: #28a745;
        color: #155724;
    }

    .alert-danger-custom {
        background-color: rgba(255, 34, 34, 0.1);
        border-color: #ff2222;
        color: #8b0000;
    }

    .input-group-currency {
        display: flex;
        align-items: center;
    }

    .currency-symbol {
        position: absolute;
        left: 12px;
        color: #999999;
        font-weight: 600;
        pointer-events: none;
    }

    .form-input[data-currency] {
        padding-left: 32px;
    }

    .button-group {
        display: flex;
        gap: 12px;
        padding-top: 24px;
        border-top: 1px solid #dddddd;
    }

    .btn-primary-custom {
        background-color: #ff2222;
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary-custom:hover {
        background-color: #cc0000;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 34, 34, 0.3);
    }

    .btn-secondary-custom {
        background-color: white;
        color: #333333;
        border: 1.5px solid #dddddd;
        padding: 12px 28px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-secondary-custom:hover {
        border-color: #ff2222;
        color: #ff2222;
    }

    .btn-danger-custom {
        background-color: #ff6b6b;
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-danger-custom:hover {
        background-color: #ff2222;
    }

    .help-text {
        font-size: 12px;
        color: #666666;
        margin-top: 6px;
    }

    .row-2col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .card-custom {
        background-color: #ffffff;
        border: 1px solid #dddddd;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        padding: 32px;
    }

    .stats-kpi {
        background: linear-gradient(135deg, #ff2222 0%, #cc0000 100%);
        color: white;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
    }

    .stats-kpi-number {
        font-size: 28px;
        font-weight: 900;
        margin: 8px 0;
    }

    .stats-kpi-label {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        opacity: 0.9;
    }
</style>

<!-- Page Header -->
<div class="product-form-header px-8 py-6 mb-8 rounded-lg">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h1 style="font-size: 32px; font-weight: 900; color: #1a1a1a; margin-bottom: 6px;">
                @(isEdit ? "Chỉnh sửa sản phẩm" : "Tạo sản phẩm mới")
            </h1>
            <p style="color: #666666; font-size: 14px;">
                @(isEdit ? $"Cập nhật: {Model?.Name}" : "Thêm sản phẩm vào kho hàng")
            </p>
        </div>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; border: 1.5px solid #ff2222; color: #ff2222; border-radius: 8px; text-decoration: none; font-weight: 600; transition: all 0.3s ease; font-size: 14px;" onmouseover="this.style.backgroundColor='rgba(255,34,34,0.1)'" onmouseout="this.style.backgroundColor='transparent'">
            <span class="material-symbols-outlined" style="font-size: 18px;">arrow_back</span> Quay lại
        </a>
    </div>
</div>

<!-- Main Form -->
<div class="card-custom mb-8">
    <form asp-area="Admin" asp-controller="Product" asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : (int?)null)" method="post" enctype="multipart/form-data" id="productForm">
        @if (isEdit) {
            <input type="hidden" asp-for="Id" />
        }

        @Html.AntiForgeryToken()

        <!-- Alert Messages -->
        @if (TempData["Success"] != null) {
            <div class="alert-custom alert-success-custom">
                <span class="material-symbols-outlined" style="font-size: 20px; flex-shrink: 0;">check_circle</span>
                <div>
                    <strong>Thành công!</strong> @TempData["Success"]
                </div>
            </div>
        }
        @if (TempData["Error"] != null) {
            <div class="alert-custom alert-danger-custom">
                <span class="material-symbols-outlined" style="font-size: 20px; flex-shrink: 0;">error</span>
                <div>
                    <strong>Lỗi!</strong> @TempData["Error"]
                </div>
            </div>
        }

        <!-- SECTION 1: Basic Information -->
        <div class="mb-8">
            <h3 class="form-section-title">
                <span class="material-symbols-outlined">info</span>
                Thông tin cơ bản
            </h3>

            <div class="row-2col">
                <!-- Product Name -->
                <div class="form-group">
                    <label class="form-label">Tên sản phẩm <span class="required">*</span></label>
                    <input asp-for="Name" class="form-input" style="width: 100%; font-size: 14px;" placeholder="VD: ASUS ROG Strix G16" />
                    <span asp-validation-for="Name" style="color: #ff2222; font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <!-- Category -->
                <div class="form-group">
                    <label class="form-label">Danh mục <span class="required">*</span></label>
                    <select asp-for="CategoryId" class="form-input" style="width: 100%;">
                        <option value="">-- Chọn danh mục --</option>
                        @if (ViewBag.Categories != null) {
                            @foreach (var cat in (List<Category>)ViewBag.Categories) {
                                <option value="@cat.Id" selected="@(Model?.CategoryId == cat.Id)">@cat.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" style="color: #ff2222; font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <!-- Brand -->
                <div class="form-group">
                    <label class="form-label">Thương hiệu <span class="required">*</span></label>
                    <select asp-for="BrandId" class="form-input" style="width: 100%;">
                        <option value="">-- Chọn thương hiệu --</option>
                        @if (ViewBag.Brands != null) {
                            @foreach (var brand in (List<Brand>)ViewBag.Brands) {
                                <option value="@brand.Id" selected="@(Model?.BrandId == brand.Id)">@brand.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="BrandId" style="color: #ff2222; font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <!-- Price -->
                <div class="form-group">
                    <label class="form-label">Giá bán (₫) <span class="required">*</span></label>
                    <div style="position: relative;">
                        <span class="currency-symbol">₫</span>
                        <input name="DefaultVariant.Price" type="number" step="1000" class="form-input" style="width: 100%; padding-left: 32px;" placeholder="0" value="@(Model?.DefaultVariant?.Price)" />
                    </div>
                </div>

                <!-- Suggested Price -->
                <div class="form-group">
                    <label class="form-label">Giá niêm yết (₫)</label>
                    <div style="position: relative;">
                        <span class="currency-symbol">₫</span>
                        <input name="DefaultVariant.ListPrice" type="number" step="1000" class="form-input" style="width: 100%; padding-left: 32px;" placeholder="0 (tùy chọn)" value="@(Model?.DefaultVariant?.ListPrice)" />
                    </div>
                    <p class="help-text">Để trống nếu giá bán = giá niêm yết</p>
                </div>
                
                <!-- Status -->
                <div class="form-group">
                    <label class="form-label">Trạng thái <span class="required">*</span></label>
                    <select asp-for="Status" class="form-input" style="width: 100%;">
                        <option value="1" selected="@(Model?.Status == 1)">✓ Hoạt động</option>
                        <option value="0" selected="@(Model?.Status == 0)">✗ Ngừng bán</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- SECTION 2: Description & Details -->
        <div class="mb-8">
            <h3 class="form-section-title">
                <span class="material-symbols-outlined">description</span>
                Mô tả & Thông tin chi tiết
            </h3>

            <!-- Product Description -->
            <div class="form-group">
                <label class="form-label">Mô tả sản phẩm <span class="required">*</span></label>
                <textarea asp-for="Description" rows="5" class="form-input" style="width: 100%; resize: vertical; font-family: monospace;" placeholder="Mô tả chi tiết về tính năng, ưu điểm sản phẩm..."></textarea>
                <p class="help-text">Hỗ trợ HTML: &lt;h4&gt;, &lt;ul&gt;, &lt;li&gt;, &lt;strong&gt;, &lt;em&gt;</p>
                <span asp-validation-for="Description" style="color: #ff2222; font-size: 12px; margin-top: 4px; display: block;"></span>
            </div>

            <!-- Technical Specs -->
            <div class="form-group">
                <label class="form-label">Thông số kỹ thuật</label>
                <textarea asp-for="Specifications" rows="3" class="form-input" style="width: 100%; resize: vertical; font-family: monospace;" placeholder="VD: Intel Core i9 | RTX 4090 | RAM 32GB | SSD 1TB"></textarea>
                <p class="help-text">Ngăn cách bằng dấu | (pipe) để hiển thị thành danh sách</p>
            </div>

            <div class="row-2col">
                <!-- Warranty -->
                <div class="form-group">
                    <label class="form-label">Thông tin bảo hành</label>
                    <input name="DefaultVariant.WarrantyInfo" class="form-input" style="width: 100%;" placeholder="VD: 24 tháng chính hãng" />
                </div>
            </div>
        </div>

        <!-- SECTION 3: Flash Sale -->
        @{
            var fs = ViewBag.FlashSale as HDKTech.Areas.Admin.Models.Promotion;
            var fsActive = fs != null && fs.IsActive;
        }
        <div class="mb-8">
            <h3 class="form-section-title">
                <span class="material-symbols-outlined" style="color:#ff2222;">local_fire_department</span>
                Flash Sale
            </h3>

            <div class="form-group" style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
                <label class="form-label mb-0">Bật Flash Sale cho sản phẩm này</label>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="isFlashSaleToggle" name="IsFlashSale" value="true"
                           @(fsActive ? "checked" : "") style="width:48px;height:24px;cursor:pointer;" />
                </div>
                @if (fsActive)
                {
                    <span class="badge" style="background:#ff2222;color:white;padding:4px 10px;border-radius:20px;font-size:12px;">
                        🔥 Đang chạy đến @fs!.EndDate.ToString("dd/MM/yyyy HH:mm")
                    </span>
                }
            </div>

            <div id="flashSaleFields" style="display:@(fsActive ? "grid" : "none");grid-template-columns:1fr 1fr 1fr;gap:20px;background:rgba(255,34,34,0.03);border:1.5px dashed #ff2222;border-radius:10px;padding:20px;">
                <div class="form-group mb-0">
                    <label class="form-label" style="color:#ff2222;">Giá Flash Sale (₫) <span class="required">*</span></label>
                    <div style="position:relative;">
                        <span class="currency-symbol">₫</span>
                        <input type="number" name="FlashSalePrice" step="1000" class="form-input"
                               style="width:100%;padding-left:32px;"
                               placeholder="Giá sale đặc biệt"
                               value="@(fs?.Value)" />
                    </div>
                    <p class="help-text">Giá bán cố định trong thời gian Flash Sale</p>
                </div>
                <div class="form-group mb-0">
                    <label class="form-label" style="color:#ff2222;">Bắt đầu <span class="required">*</span></label>
                    <input type="datetime-local" name="FlashSaleStart" class="form-input" style="width:100%;"
                           value="@(fs?.StartDate.ToString("yyyy-MM-ddTHH:mm"))" />
                </div>
                <div class="form-group mb-0">
                    <label class="form-label" style="color:#ff2222;">Kết thúc <span class="required">*</span></label>
                    <input type="datetime-local" name="FlashSaleEnd" class="form-input" style="width:100%;"
                           value="@(fs?.EndDate.ToString("yyyy-MM-ddTHH:mm"))" />
                </div>
            </div>
            <p class="help-text mt-2">
                <i class="bi bi-info-circle me-1"></i>
                Flash Sale sẽ tự động hiển thị giá khuyến mãi trên trang sản phẩm. Quản lý chi tiết tại
                <a href="/admin/promotion" style="color:#ff2222;">Quản lý Khuyến mãi →</a>
            </p>
        </div>

        <!-- Form Actions -->
        <div class="button-group">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn-secondary-custom">
                <span class="material-symbols-outlined" style="font-size: 18px;">close</span>
                Hủy
            </a>

            @if (isEdit) {
                <button type="button" class="btn-danger-custom" onclick="if(confirm('Xóa sản phẩm này?')) document.getElementById('deleteForm').submit();">
                    <span class="material-symbols-outlined" style="font-size: 18px;">delete</span>
                    Xóa sản phẩm
                </button>
            }

            <button type="submit" class="btn-primary-custom" style="margin-left: auto;">
                <span class="material-symbols-outlined" style="font-size: 18px;">@(isEdit ? "check_circle" : "add_circle")</span>
                @(isEdit ? "Cập nhật sản phẩm" : "Tạo sản phẩm")
            </button>
        </div>
    </form>

    <!-- Delete Form (Hidden) -->
    @if (isEdit) {
        <form id="deleteForm" asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display: none;">
            @Html.AntiForgeryToken()
        </form>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Flash Sale toggle
        const flashToggle = document.getElementById('isFlashSaleToggle');
        const flashFields = document.getElementById('flashSaleFields');
        if (flashToggle && flashFields) {
            flashToggle.addEventListener('change', function() {
                flashFields.style.display = this.checked ? 'grid' : 'none';
                if (this.checked) {
                    // Set default dates if empty
                    const startInput = flashFields.querySelector('[name="FlashSaleStart"]');
                    const endInput   = flashFields.querySelector('[name="FlashSaleEnd"]');
                    if (startInput && !startInput.value) {
                        const now = new Date();
                        startInput.value = now.toISOString().slice(0, 16);
                    }
                    if (endInput && !endInput.value) {
                        const tomorrow = new Date(Date.now() + 86400000);
                        endInput.value = tomorrow.toISOString().slice(0, 16);
                    }
                }
            });
        }

        const productForm = document.getElementById('productForm');

        productForm.addEventListener('submit', function(e) {
            const name = document.querySelector('[name="Name"]').value.trim();
            const categoryId = document.querySelector('[name="CategoryId"]').value;
            const brandId = document.querySelector('[name="BrandId"]').value;
            const price = parseFloat(document.querySelector('[name="DefaultVariant.Price"]').value);
            const description = document.querySelector('[name="Description"]').value.trim();

            if (!name) { alert('⚠️ Vui lòng nhập tên sản phẩm'); e.preventDefault(); return; }
            if (!categoryId) { alert('⚠️ Vui lòng chọn danh mục'); e.preventDefault(); return; }
            if (!brandId) { alert('⚠️ Vui lòng chọn thương hiệu'); e.preventDefault(); return; }
            if (!price || price <= 0) { alert('⚠️ Giá bán phải lớn hơn 0'); e.preventDefault(); return; }
            if (!description) { alert('⚠️ Vui lòng nhập mô tả'); e.preventDefault(); return; }
        });
    });
</script>
