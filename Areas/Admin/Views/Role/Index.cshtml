@model List<HDKTech.Areas.Admin.Controllers.IdentityRoleListItem>
@{
    ViewData["Title"] = "Phân quyền - Quản lý Vai trò";
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-shield-lock me-2 text-primary"></i>Phân quyền</h4>
        <small class="text-muted">Quản lý vai trò và quyền hạn người dùng trong hệ thống</small>
    </div>
    <a asp-area="Admin" asp-controller="Role" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Thêm vai trò mới
    </a>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-primary">@Model.Count</div>
            <small class="text-muted">Tổng vai trò</small>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-success">@Model.Sum(r => r.UserCount)</div>
            <small class="text-muted">Tổng người dùng</small>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-info">@HDKTech.Areas.Admin.Controllers.RoleController.AllSystemPermissions.Count</div>
            <small class="text-muted">Tổng quyền hệ thống</small>
        </div>
    </div>
</div>

<!-- Bảng vai trò -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Tên vai trò</th>
                        <th class="text-center">Người dùng</th>
                        <th class="text-center">Số quyền</th>
                        <th class="text-end pe-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        int idx = 1;
                        @foreach (var role in Model)
                        {
                            var isProtected = new[] { "Admin", "Manager", "User", "WarehouseStaff" }
                                .Contains(role.Name, StringComparer.OrdinalIgnoreCase);
                            var badgeColor = role.Name switch
                            {
                                "Admin"          => "danger",
                                "Manager"        => "warning text-dark",
                                "WarehouseStaff" => "info text-dark",
                                _                => "secondary"
                            };

                            <tr>
                                <td class="ps-3 text-muted small">@(idx++)</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white bg-primary"
                                             style="width:34px;height:34px;font-size:.8rem;flex-shrink:0">
                                            @role.Name[0].ToString().ToUpper()
                                        </div>
                                        <div>
                                            <span class="fw-semibold">@role.Name</span>
                                            @if (isProtected)
                                            {
                                                <span class="badge bg-light text-secondary border ms-1" style="font-size:.65rem">
                                                    <i class="bi bi-lock-fill me-1"></i>Hệ thống
                                                </span>
                                            }
                                            <div class="text-muted" style="font-size:.7rem">ID: @role.Id[..8]…</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary">
                                        <i class="bi bi-people me-1"></i>@role.UserCount
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-info text-dark">
                                        <i class="bi bi-key me-1"></i>@role.PermissionCount / @HDKTech.Areas.Admin.Controllers.RoleController.AllSystemPermissions.Count
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-area="Admin" asp-controller="Role" asp-action="ManagePermissions"
                                           asp-route-roleName="@role.Name"
                                           class="btn btn-outline-primary" title="Quản lý quyền">
                                            <i class="bi bi-shield-check me-1"></i>Phân quyền
                                        </a>
                                        @if (!isProtected)
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-delete-role"
                                                    data-id="@role.Id" data-name="@Html.Encode(role.Name)"
                                                    title="Xoá vai trò">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-shield-x fs-2 d-block mb-2"></i>
                                Chưa có vai trò nào.
                                <a asp-area="Admin" asp-controller="Role" asp-action="Create">Tạo vai trò đầu tiên</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger"><i class="bi bi-shield-x me-2"></i>Xoá Vai trò</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc muốn xoá vai trò <strong id="deleteRoleName"></strong>?
                <div class="alert alert-warning mt-3 mb-0 py-2 small">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    Tất cả quyền hạn (claims) của vai trò này sẽ bị xoá vĩnh viễn. Hành động được ghi vào Audit Log.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteRole">
                    <i class="bi bi-trash me-1"></i>Xoá
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@Html.AntiForgeryToken()
<script>
    let deleteRoleId   = null;
    let deleteModal    = null;

    document.querySelectorAll('.btn-delete-role').forEach(btn => {
        btn.addEventListener('click', function () {
            deleteRoleId = this.dataset.id;
            document.getElementById('deleteRoleName').textContent = this.dataset.name;
            deleteModal  = new bootstrap.Modal(document.getElementById('deleteRoleModal'));
            deleteModal.show();
        });
    });

    document.getElementById('confirmDeleteRole')?.addEventListener('click', async function () {
        if (!deleteRoleId) return;
        const btn   = this;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang xoá...';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const res   = await fetch('/admin/role/delete', {
                method:  'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body:    `roleId=${encodeURIComponent(deleteRoleId)}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });
            const data = await res.json();
            if (data.success) {
                deleteModal?.hide();
                window.location.reload();
            } else {
                alert(data.message || 'Lỗi khi xoá vai trò');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-trash me-1"></i>Xoá';
            }
        } catch (e) {
            alert('Lỗi kết nối máy chủ');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-trash me-1"></i>Xoá';
        }
    });
</script>
}
