@model HDKTech.Areas.Admin.ViewModels.RoleIndexViewModel
@{
    ViewData["Title"] = "Phân quyền - Quản lý Vai trò";
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-shield-lock me-2 text-primary"></i>Phân quyền</h4>
        <small class="text-muted">Quản lý vai trò và quyền hạn người dùng trong hệ thống</small>
    </div>
    <a asp-area="Admin" asp-controller="Role" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Thêm vai trò mới
    </a>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-primary">@Model.TotalRoles</div>
            <small class="text-muted">Tổng vai trò</small>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-success">@Model.ActiveRoles</div>
            <small class="text-muted">Đang hoạt động</small>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fw-bold fs-4 text-info">@Model.TotalPermissions</div>
            <small class="text-muted">Tổng quyền hạn</small>
        </div>
    </div>
</div>

<!-- Search Form -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" asp-area="Admin" asp-controller="Role" asp-action="Index"
              class="row g-2 align-items-end">
            <div class="col-12 col-md-6">
                <input type="text" name="searchTerm" value="@Model.SearchTerm"
                       class="form-control form-control-sm" placeholder="Tìm theo tên vai trò, mô tả..." />
            </div>
            <div class="col-6 col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>Tìm
                </button>
            </div>
            <div class="col-6 col-md-2">
                <a asp-area="Admin" asp-controller="Role" asp-action="Index"
                   class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-x me-1"></i>Xoá lọc
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Bảng phân quyền: responsive + table-hover -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Tên vai trò</th>
                        <th>Mô tả</th>
                        <th>Số quyền</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th class="text-end pe-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Roles.Any())
                    {
                        @foreach (var role in Model.Roles)
                        {
                            int permCount = role.RolePermissions?.Count ?? 0;
                            <tr>
                                <td class="ps-3 text-muted small">@role.RoleId</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold"
                                             style="width:32px;height:32px;font-size:.75rem">
                                            @(role.RoleName.Length > 0 ? role.RoleName[0].ToString().ToUpper() : "R")
                                        </div>
                                        <span class="fw-semibold">@role.RoleName</span>
                                    </div>
                                </td>
                                <td>
                                    <small class="text-muted">
                                        @(string.IsNullOrEmpty(role.Description) ? "—" : role.Description)
                                    </small>
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        <i class="bi bi-key me-1"></i>@permCount quyền
                                    </span>
                                </td>
                                <td>
                                    @if (role.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-pause-circle me-1"></i>Tạm dừng
                                        </span>
                                    }
                                </td>
                                <td>
                                    <small class="text-muted">@role.CreatedAt.ToString("dd/MM/yyyy")</small>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-area="Admin" asp-controller="Role" asp-action="Details" asp-route-id="@role.RoleId"
                                           class="btn btn-outline-secondary" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="Role" asp-action="Edit" asp-route-id="@role.RoleId"
                                           class="btn btn-outline-primary" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger btn-delete-role"
                                                data-id="@role.RoleId" data-name="@Html.Encode(role.RoleName)"
                                                title="Xoá">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="bi bi-shield-x fs-2 d-block mb-2"></i>
                                Chưa có vai trò nào.
                                <a asp-area="Admin" asp-controller="Role" asp-action="Create">Tạo vai trò đầu tiên</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex align-items-center justify-content-between">
            <small class="text-muted">
                Trang @Model.CurrentPage / @Model.TotalPages
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Role" asp-action="Index"
                           asp-route-pageNumber="@(Model.CurrentPage - 1)"
                           asp-route-searchTerm="@Model.SearchTerm">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-area="Admin" asp-controller="Role" asp-action="Index"
                               asp-route-pageNumber="@i"
                               asp-route-searchTerm="@Model.SearchTerm">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Role" asp-action="Index"
                           asp-route-pageNumber="@(Model.CurrentPage + 1)"
                           asp-route-searchTerm="@Model.SearchTerm">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger"><i class="bi bi-shield-x me-2"></i>Xoá Vai trò</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc muốn xoá vai trò <strong id="deleteRoleName"></strong>?
                <br><small class="text-muted mt-1 d-block">
                    <i class="bi bi-exclamation-triangle me-1 text-warning"></i>
                    Tất cả quyền hạn của vai trò này sẽ bị xoá. Hành động được ghi vào Audit Log.
                </small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteRole">
                    <i class="bi bi-trash me-1"></i>Xoá
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let deleteRoleId = null;

    document.querySelectorAll('.btn-delete-role').forEach(btn => {
        btn.addEventListener('click', function () {
            deleteRoleId = this.dataset.id;
            document.getElementById('deleteRoleName').textContent = this.dataset.name;
            new bootstrap.Modal(document.getElementById('deleteRoleModal')).show();
        });
    });

    document.getElementById('confirmDeleteRole')?.addEventListener('click', async function () {
        if (!deleteRoleId) return;
        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const res   = await fetch('/admin/role/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `roleId=${deleteRoleId}&__RequestVerificationToken=${encodeURIComponent(token ?? '')}`
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.message || 'Lỗi khi xoá vai trò');
            }
        } catch (e) {
            alert('Lỗi kết nối');
        }
    });
</script>
@Html.AntiForgeryToken()
}
