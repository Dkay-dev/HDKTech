@model Promotion

@{
    ViewData["Title"] = "Tạo Khuyến mãi Mới";
}

<div class="mb-4">
    <h1 class="display-5 fw-bold mb-2">Tạo Khuyến mãi Mới</h1>
    <p class="text-muted">Thêm một chiến dịch khuyến mãi mới</p>
</div>

<div class="row">
    <!-- Form -->
    <div class="col-lg-8 col-xl-9">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <!-- Tên chiến dịch -->
                    <div class="mb-3">
                        <label asp-for="CampaignName" class="form-label fw-bold">
                            Tên chiến dịch <span class="text-danger">*</span>
                        </label>
                        <input type="text" asp-for="CampaignName" class="form-control form-control-sm" placeholder="VD: Back to School 2024" />
                        <span asp-validation-for="CampaignName" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Mô tả -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control form-control-sm" rows="3" placeholder="Mô tả về chiến dịch..."></textarea>
                    </div>

                    <!-- Danh mục áp dụng -->
                    <div class="mb-3">
                        <label asp-for="ApplicableCategory" class="form-label fw-bold">Danh mục áp dụng</label>
                        <input type="text" asp-for="ApplicableCategory" class="form-control form-control-sm" placeholder="VD: Laptop & Accessories" />
                    </div>

                    <!-- Ngày bắt đầu & kết thúc -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label fw-bold">
                                Ngày bắt đầu <span class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" asp-for="StartDate" class="form-control form-control-sm" />
                            <span asp-validation-for="StartDate" class="invalid-feedback d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label fw-bold">
                                Ngày kết thúc <span class="text-danger">*</span>
                            </label>
                            <input type="datetime-local" asp-for="EndDate" class="form-control form-control-sm" />
                            <span asp-validation-for="EndDate" class="invalid-feedback d-block"></span>
                        </div>
                    </div>

                    <!-- Loại khuyến mãi -->
                    <div class="mb-3">
                        <label asp-for="PromotionType" class="form-label fw-bold">
                            Loại khuyến mãi <span class="text-danger">*</span>
                        </label>
                        <select asp-for="PromotionType" id="PromotionType" class="form-select form-select-sm">
                            <option value="">-- Chọn loại --</option>
                            <option value="Percentage">Giảm giá %</option>
                            <option value="FixedAmount">Giảm giá cố định (VNĐ)</option>
                            <option value="FreeShip">Miễn phí vận chuyển</option>
                        </select>
                        <span asp-validation-for="PromotionType" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Giá trị khuyến mãi -->
                    <div class="mb-3">
                        <label asp-for="Value" class="form-label fw-bold">
                            Giá trị <span class="text-danger">*</span>
                        </label>
                        <div class="input-group input-group-sm">
                            <input type="number" asp-for="Value" step="0.01" class="form-control" placeholder="0" />
                            <span id="unit" class="input-group-text fw-bold">%</span>
                        </div>
                        <span asp-validation-for="Value" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Mã khuyến mãi -->
                    <div class="mb-3">
                        <label asp-for="PromoCode" class="form-label fw-bold">Mã khuyến mãi</label>
                        <input type="text" asp-for="PromoCode" class="form-control form-control-sm" placeholder="VD: BACK2024" />
                        <small class="text-muted">Để trống nếu không sử dụng mã</small>
                    </div>

                    <!-- Số lượng tối đa & Trạng thái -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MaxUsageCount" class="form-label fw-bold">Số lượng tối đa</label>
                            <input type="number" asp-for="MaxUsageCount" class="form-control form-control-sm" placeholder="Không giới hạn nếu để trống" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Trạng thái</label>
                            <div class="form-check">
                                <input type="checkbox" asp-for="IsActive" class="form-check-input" id="IsActive" checked />
                                <label class="form-check-label" for="IsActive">Kích hoạt</label>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-2 pt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Tạo chiến dịch
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Preview Sidebar -->
    <div class="col-lg-4 col-xl-3">
        <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
            <div class="card-body">
                <h5 class="card-title fw-bold mb-4">
                    <i class="fas fa-eye me-2"></i>Xem trước
                </h5>

                <div class="mb-3">
                    <small class="text-muted fw-bold d-block mb-1">Tên chiến dịch</small>
                    <p id="previewName" class="mb-0 fw-bold">-</p>
                </div>

                <hr>

                <div class="mb-3">
                    <small class="text-muted fw-bold d-block mb-1">Mức giảm</small>
                    <p id="previewPromo" class="mb-0 fs-5 fw-bold text-primary">-</p>
                </div>

                <hr>

                <div class="mb-3">
                    <small class="text-muted fw-bold d-block mb-1">Thời gian chạy</small>
                    <small id="previewTime" class="text-muted d-block">-</small>
                </div>

                <hr>

                <div>
                    <small class="text-muted fw-bold d-block mb-1">Trạng thái</small>
                    <p id="previewStatus" class="mb-0">
                        <span class="badge bg-warning rounded-pill text-dark">
                            <i class="fas fa-clock me-1"></i>Sắp diễn ra
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const loaiSelect = document.getElementById('PromotionType');
    const unitSpan = document.getElementById('unit');
    const previewName = document.getElementById('previewName');
    const previewPromo = document.getElementById('previewPromo');
    const previewTime = document.getElementById('previewTime');

    loaiSelect.addEventListener('change', function() {
        if (this.value === 'Percentage') {
            unitSpan.textContent = '%';
        } else if (this.value === 'FixedAmount') {
            unitSpan.textContent = '₫';
        } else {
            unitSpan.textContent = '';
        }
    });

    document.getElementById('CampaignName').addEventListener('input', (e) => {
        previewName.textContent = e.target.value || '-';
    });

    document.getElementById('Value').addEventListener('input', updatePreview);
    document.getElementById('PromotionType').addEventListener('change', updatePreview);

    function updatePreview() {
        const Value = document.getElementById('Value').value;
        const loai = loaiSelect.value;
        
        let text = '-';
        if (Value && loai) {
            if (loai === 'Percentage') text = `Giảm ${Value}%`;
            else if (loai === 'FixedAmount') text = `Giảm ${parseInt(Value).toLocaleString('vi-VN')}₫`;
            else text = `Miễn phí vận chuyển`;
        }
        previewPromo.textContent = text;
    }
</script>

