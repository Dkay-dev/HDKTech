@model IEnumerable<Promotion>

@{
    ViewData["Title"] = "Quản lý Khuyến mãi";
}

<!-- Header Section -->
<div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between mb-5 gap-4">
    <div>
        <h1 class="display-4 fw-bold mb-2">Quản lý Khuyến mãi</h1>
        <p class="text-muted">Quản lý các chiến dịch khuyến mãi, theo dõi lượt sử dụng và hiệu suất của các mã giảm giá.</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary align-self-start d-flex align-items-center gap-2">
        <i class="fas fa-plus-circle"></i>
        Thêm Khuyến mãi Mới
    </a>
</div>

<!-- Quick Stats Cards -->
<div class="row mb-5">
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-danger-light p-3 me-3">
                        <i class="fas fa-megaphone text-danger fs-5"></i>
                    </div>
                </div>
                <p class="text-muted small fw-bold mb-1">Tổng số chiến dịch</p>
                <h3 class="fw-bold">@Model.Count()</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-success-light p-3 me-3">
                        <i class="fas fa-play text-success fs-5"></i>
                    </div>
                </div>
                <p class="text-muted small fw-bold mb-1">Đang chạy</p>
                <h3 class="fw-bold">@Model.Count(k => k.IsCurrentlyActive)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle bg-warning-light p-3 me-3">
                        <i class="fas fa-calendar text-warning fs-5"></i>
                    </div>
                </div>
                <p class="text-muted small fw-bold mb-1">Sắp diễn ra</p>
                <h3 class="fw-bold">@Model.Count(k => !k.IsCurrentlyActive && k.StartDate > DateTime.Now)</h3>
            </div>
        </div>
    </div>
</div>

<!-- Promotions Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-light border-bottom d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">
            <i class="fas fa-list me-2"></i>Danh sách chiến dịch khuyến mãi
        </h5>
        <button class="btn btn-sm btn-outline-secondary" onclick="exportCSV()">
            <i class="fas fa-download me-1"></i>Export CSV
        </button>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-tag fs-1 text-muted mb-3 d-block"></i>
                <p class="text-muted">Không có chiến dịch nào. <a href="@Url.Action("Create")" class="fw-bold">Tạo chiến dịch mới</a></p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Tên chiến dịch</th>
                            <th>Thời gian</th>
                            <th>Mức giảm</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var promo in Model.OrderByDescending(p => p.CreatedAt))
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-light rounded p-2">
                                            <i class="fas fa-percentage text-danger"></i>
                                        </div>
                                        <div>
                                            <p class="mb-0 fw-bold">@promo.CampaignName</p>
                                            <small class="text-muted">@promo.ApplicableCategory</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div>
                                        <small class="d-block fw-bold">
                                            <i class="fas fa-calendar me-1"></i>@promo.StartDate.ToString("dd/MM/yyyy") - @promo.EndDate.ToString("dd/MM/yyyy")
                                        </small>
                                        <small class="text-muted d-block">
                                            @{
                                                var remaining = (promo.EndDate - DateTime.Now).TotalDays;
                                                string remainingText = "Không xác định";
                                                if (remaining < 0)
                                                {
                                                    remainingText = "Đã kết thúc";
                                                }
                                                else if (remaining > 1)
                                                {
                                                    remainingText = $"Còn {remaining:0} ngày";
                                                }
                                                else if (remaining > 0)
                                                {
                                                    remainingText = "Còn <1 ngày";
                                                }
                                                else
                                                {
                                                    remainingText = "Hôm nay kết thúc";
                                                }
                                            }
                                            @remainingText
                                        </small>
                                    </div>
                                </td>
                                <td>
                                    @if (promo.PromotionType == "Percentage")
                                    {
                                        <span class="badge bg-danger">@promo.Value% OFF</span>
                                    }
                                    else if (promo.PromotionType == "FixedAmount")
                                    {
                                        <span class="badge bg-primary">-@promo.Value.ToString("#,##0")₫</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Miễn phí vận chuyển</span>
                                    }
                                </td>
                                <td>
                                    @if (promo.IsCurrentlyActive)
                                    {
                                        <span class="badge bg-success rounded-pill">
                                            <i class="fas fa-circle-notch fa-spin me-1"></i>Đang chạy
                                        </span>
                                    }
                                    else if (promo.StartDate > DateTime.Now)
                                    {
                                        <span class="badge bg-warning rounded-pill text-dark">
                                            <i class="fas fa-clock me-1"></i>Sắp diễn ra
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">
                                            <i class="fas fa-check-circle me-1"></i>Kết thúc
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="@Url.Action("Details", new { id = promo.Id })" class="btn btn-outline-info" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = promo.Id })" class="btn btn-outline-primary" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="@Url.Action("Delete", new { id = promo.Id })" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Xóa" onclick="return confirm('Bạn chắc chắn muốn xóa chiến dịch này?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<script>
    function exportCSV() {
        alert('Tính năng Export CSV sẽ được triển khai.');
    }
</script>

