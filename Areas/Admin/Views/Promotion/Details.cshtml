@model Promotion

@{
    ViewData["Title"] = "Chi tiết Khuyến mãi";
    var discount = Model.PromotionType == "Percentage" ? $"{Model.Value}%" : $"-{Model.Value:N0}₫";
    var daysLeft = (Model.EndDate - DateTime.Now).TotalDays;
}

<!-- Header -->
<div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between mb-5 gap-3">
    <div>
        <h1 class="display-4 fw-bold mb-2">@Model.CampaignName</h1>
        <p class="text-muted">Chi tiết đầy đủ về chương trình khuyến mãi</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary">
            <i class="fas fa-edit me-2"></i>Chỉnh sửa
        </a>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>
</div>

<!-- Main Content -->
<div class="row mb-4">
    <!-- Left: Main Info -->
    <div class="col-lg-8 col-xl-9">
        <!-- Status Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title fw-bold mb-0">Trạng thái</h5>
                    @if (Model.IsCurrentlyActive)
                    {
                        <span class="badge bg-success rounded-pill">
                            <i class="fas fa-play me-1"></i>Đang chạy
                        </span>
                    }
                    else if (Model.StartDate > DateTime.Now)
                    {
                        <span class="badge bg-warning rounded-pill text-dark">
                            <i class="fas fa-clock me-1"></i>Sắp diễn ra
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary rounded-pill">
                            <i class="fas fa-check me-1"></i>Kết thúc
                        </span>
                    }
                </div>

                @if (Model.IsCurrentlyActive)
                {
                    <div class="alert alert-success mb-0" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        <strong>Khuyến mãi đang hoạt động</strong> - Sẽ kết thúc sau <strong>@Math.Ceiling(daysLeft) ngày</strong>
                    </div>
                }
                else if (Model.StartDate > DateTime.Now)
                {
                    <div class="alert alert-warning mb-0" role="alert">
                        <i class="fas fa-calendar me-2"></i>
                        <strong>Khuyến mãi sắp diễn ra</strong> - Sẽ bắt đầu sau <strong>@Math.Ceiling((Model.StartDate - DateTime.Now).TotalDays) ngày</strong>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary mb-0" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Khuyến mãi đã kết thúc</strong> vào <strong>@Model.EndDate.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                }
            </div>
        </div>

        <!-- Details Grid -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold">
                    <i class="fas fa-details me-2"></i>Thông tin chi tiết
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <!-- Discount Value -->
                    <div class="col-md-6">
                        <div class="border-start border-primary border-4 ps-3">
                            <small class="text-muted fw-bold d-block mb-1">
                                <i class="fas fa-percentage me-1"></i>Mức giảm giá
                            </small>
                            <p class="mb-0 fs-3 fw-bold text-primary">@discount</p>
                            <small class="text-muted d-block mt-1">@(Model.PromotionType == "Percentage" ? "Phần trăm giảm" : "Số tiền giảm")</small>
                        </div>
                    </div>

                    <!-- Campaign Code -->
                    <div class="col-md-6">
                        <div class="border-start border-info border-4 ps-3">
                            <small class="text-muted fw-bold d-block mb-1">
                                <i class="fas fa-barcode me-1"></i>Mã chiến dịch
                            </small>
                            <p class="mb-0 fs-5 fw-bold font-monospace text-info">@Model.PromoCode</p>
                            <small class="text-muted d-block mt-1">Dùng mã này khi tạo đơn hàng</small>
                        </div>
                    </div>

                    <!-- Start Date -->
                    <div class="col-md-6">
                        <div class="border-start border-success border-4 ps-3">
                            <small class="text-muted fw-bold d-block mb-1">
                                <i class="fas fa-play-circle me-1"></i>Ngày bắt đầu
                            </small>
                            <p class="mb-0 fw-bold">@Model.StartDate.ToString("dd/MM/yyyy")</p>
                            <small class="text-muted d-block">@Model.StartDate.ToString("HH:mm:ss")</small>
                        </div>
                    </div>

                    <!-- End Date -->
                    <div class="col-md-6">
                        <div class="border-start border-danger border-4 ps-3">
                            <small class="text-muted fw-bold d-block mb-1">
                                <i class="fas fa-stop-circle me-1"></i>Ngày kết thúc
                            </small>
                            <p class="mb-0 fw-bold">@Model.EndDate.ToString("dd/MM/yyyy")</p>
                            <small class="text-muted d-block">@Model.EndDate.ToString("HH:mm:ss")</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Description -->
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-file-alt me-2"></i>Mô tả
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted" style="white-space: pre-wrap;">@Model.Description</p>
                </div>
            </div>
        }

        <!-- Usage Stats -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0 fw-bold">
                    <i class="fas fa-chart-bar me-2"></i>Thống kê sử dụng
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded border border-primary border-2">
                            <small class="text-muted fw-bold d-block mb-1">
                                <i class="fas fa-history me-1"></i>Số lần sử dụng
                            </small>
                            <p class="mb-0 fs-4 fw-bold text-primary">@Model.UsageCount</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded border border-info border-2">
                            <small class="text-muted fw-bold d-block mb-1">
                                <i class="fas fa-money-bill-wave me-1"></i>Giá trị khuyến mãi
                            </small>
                            <p class="mb-0 fs-4 fw-bold text-info">@(Model.PromotionType == "Percentage" ? Model.Value + "%" : "₫" + Model.Value.ToString("N0"))</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Quick Info Sidebar -->
    <div class="col-lg-4 col-xl-3">
        <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
            <div class="card-body">
                <h5 class="card-title fw-bold mb-4">
                    <i class="fas fa-info-circle me-2"></i>Thông tin nhanh
                </h5>

                <div class="mb-3">
                    <small class="text-muted fw-bold d-block mb-1">
                        <i class="fas fa-tag me-1"></i>Loại khuyến mãi
                    </small>
                    <p class="mb-0 small fw-semibold">
                        @if (Model.PromotionType == "Percentage")
                        {
                            <span class="badge bg-danger">Giảm theo %</span>
                        }
                        else if (Model.PromotionType == "FixedAmount")
                        {
                            <span class="badge bg-primary">Giảm tiền cố định</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Miễn phí vận chuyển</span>
                        }
                    </p>
                </div>

                <hr>

                <div class="mb-3">
                    <small class="text-muted fw-bold d-block mb-1">
                        <i class="fas fa-hourglass-half me-1"></i>Thời gian chạy
                    </small>
                    <p class="mb-0 small">@((Model.EndDate - Model.StartDate).TotalDays.ToString("F0")) ngày</p>
                </div>

                <hr>

                <div class="mb-3">
                    <small class="text-muted fw-bold d-block mb-1">
                        <i class="fas fa-calendar-alt me-1"></i>Ngày tạo
                    </small>
                    <p class="mb-0 small">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                </div>

                @if (Model.UpdatedAt.HasValue)
                {
                    <hr>
                    <div class="mb-3">
                        <small class="text-muted fw-bold d-block mb-1">
                            <i class="fas fa-sync me-1"></i>Cập nhật lần cuối
                        </small>
                        <p class="mb-0 small">@Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                }

                <hr>

                <!-- Actions -->
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary btn-sm">
                        <i class="fas fa-edit me-1"></i>Chỉnh sửa
                    </a>
                    <form method="post" action="@Url.Action("Delete", new { id = Model.Id })" onsubmit="return confirm('Bạn chắc chắn muốn xóa khuyến mãi này?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="fas fa-trash me-1"></i>Xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

