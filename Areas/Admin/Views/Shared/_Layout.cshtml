@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HDKTech Admin</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <!-- Google Material Symbols (dùng trong các Admin Views) -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <!-- Giai đoạn 4: SweetAlert2 — Luxury Toast Notifications -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <!-- Admin Panel CSS -->
    <link rel="stylesheet" href="~/admin/css/admin-main.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body class="hdk-admin-body">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- ADMIN TOPBAR                                                       -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <nav class="navbar navbar-dark hdk-admin-topbar px-3 sticky-top">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-sm text-white" id="sidebarToggleBtn" aria-label="Toggle sidebar">
                <i class="bi bi-list fs-5"></i>
            </button>
            <a class="navbar-brand d-flex align-items-center gap-2" href="/admin/dashboard">
                <div class="hdk-logo-admin">
                    <span style="color: #ffffff; font-weight: 800; font-size: 1.4rem;">HDK</span>
                    <span style="color: #ef4444; font-weight: 800; font-size: 1.4rem;">Tech</span>
                </div>
    
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="badge ms-1" style="background-color: rgba(201, 168, 76, 0.15); color: #c9a84c; font-size: 0.65rem; border: 1px solid rgba(201, 168, 76, 0.3);">
                        @(User.IsInRole("Admin") ? "ADMIN" : "MANAGER")
                    </span>
                }
            </a>
        </div>

        <div class="d-flex align-items-center gap-3">
            <a href="/" class="btn btn-sm btn-outline-light" target="_blank">
                <i class="bi bi-shop me-1"></i> Xem trang Guest
            </a>
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-light dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle me-1"></i>
                    @User.Identity?.Name
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <form method="post" asp-area="Identity" asp-page="/Account/Logout">
                            @Html.AntiForgeryToken()
                            <button class="dropdown-item text-danger" type="submit">
                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="d-flex" id="hdk-admin-wrapper">

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR                                                        -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- SIDEBAR — Sprint 3: Dynamic theo Policy (AuthorizeAsync)       -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <nav id="hdk-admin-sidebar" class="hdk-admin-sidebar d-flex flex-column">
            <ul class="nav flex-column pt-3 px-2">

                @* Dashboard — mọi role đã authed đều thấy *@
                <li class="nav-item">
                    <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                       href="/admin/dashboard">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RevenueAnalytics" ? "active" : "")"
                           href="/admin/revenueanalytics">
                        <i class="bi bi-graph-up-arrow me-2"></i> Thống kê Doanh thu
                    </a>
                </li>

                @* ── QUẢN LÝ HÀNG HOÁ ──────────────────────────────────── *@
                @{
                    var canProduct   = (await AuthorizationService.AuthorizeAsync(User, "Product.Read")).Succeeded;
                    var canInventory = (await AuthorizationService.AuthorizeAsync(User, "Inventory.Read")).Succeeded;
                    var canCategory  = (await AuthorizationService.AuthorizeAsync(User, "Category.Read")).Succeeded;
                    var canBrand     = (await AuthorizationService.AuthorizeAsync(User, "Brand.Read")).Succeeded;
                }
                @if (canProduct || canInventory || canCategory || canBrand)
                {
                <li class="nav-item mt-2">
                    <span class="nav-section-label px-3">QUẢN LÝ HÀNG HOÁ</span>
                </li>
                }
                @if (canProduct)
                {
                <li class="nav-item">
                    <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
                       href="/admin/product">
                        <i class="bi bi-box-seam me-2"></i> Sản phẩm
                    </a>
                </li>
                }
                @if (canInventory)
                {
                <li class="nav-item">
                        <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")"
                           href="/admin/inventory">
                            <i class="bi bi-boxes me-2"></i> Quản lý Kho
                        </a>
                    </li>
                }
                @if (canCategory)
                {
                    <li class="nav-item">
                    <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                       href="/admin/category">
                        <i class="bi bi-tags me-2"></i> Danh mục
                    </a>
                </li>
                }
                @if (canBrand)
                {
                <li class="nav-item">
                    <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Brand" ? "active" : "")"
                       href="/admin/brand">
                        <i class="bi bi-award me-2"></i> Thương hiệu
                    </a>
                </li>
                }

                @* ── KINH DOANH ─────────────────────────────────────────── *@
                @{
                    var canOrder     = (await AuthorizationService.AuthorizeAsync(User, "Order.Read")).Succeeded;
                    var canReport    = (await AuthorizationService.AuthorizeAsync(User, "Report.Export")).Succeeded;
                    var canPromotion = (await AuthorizationService.AuthorizeAsync(User, "Promotion.Read")).Succeeded;
                }
                @if (canOrder || canReport || canPromotion)
                {
                <li class="nav-item mt-2">
                    <span class="nav-section-label px-3">KINH DOANH</span>
                </li>
                }
                @if (canOrder)
                {
                <li class="nav-item">
                    <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")"
                       href="/admin/order">
                        <i class="bi bi-receipt me-2"></i> Đơn hàng
                    </a>
                </li>
                }
                @if (canReport)
                {
                    <li class="nav-item">
                        <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")"
                           href="/admin/reports">
                            <i class="bi bi-file-earmark-spreadsheet me-2"></i> Báo cáo Excel
                        </a>
                    </li>
                }
                @if (canPromotion)
                {
                    <li class="nav-item">
                        <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Promotion" ? "active" : "")"
                           href="/admin/promotion">
                            <i class="bi bi-percent me-2"></i> Khuyến mãi
                        </a>
                    </li>
                }

                @* ── MARKETING ──────────────────────────────────────────── *@
                @{
                    var canBanner = (await AuthorizationService.AuthorizeAsync(User, "Banner.Read")).Succeeded;
                }
                @if (canBanner)
                {
                <li class="nav-item mt-2">
                    <span class="nav-section-label px-3">MARKETING</span>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Banner" ? "active" : "")"
                           href="/admin/banner">
                            <i class="bi bi-image me-2"></i> Banner
                        </a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "BannerAnalytics" ? "active" : "")"
                       href="/admin/banneranalytics">
                        <i class="bi bi-bar-chart-line me-2"></i> Banner Analytics
                    </a>
                </li>
                }

                @* ── HỆ THỐNG — Admin + Policy ──────────────────────────── *@
                @{
                    var canRole      = (await AuthorizationService.AuthorizeAsync(User, "Role.Read")).Succeeded;
                    var canSystemLog = (await AuthorizationService.AuthorizeAsync(User, "SystemLog.Read")).Succeeded;
                    var canUsers     = User.IsInRole("Admin");
                }
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item mt-2">
                        <span class="nav-section-label px-3">HỆ THỐNG</span>
                    </li>
    
                    @* Trang quản lý danh sách User & Khách hàng *@
                    <li class="nav-item">
                        <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                               href="/admin/users">
                            <i class="bi bi-people-fill me-2"></i> Quản lý Người dùng
                        </a>
                    </li>

                    @* Trang Ma trận phân quyền (Gộp từ Phân quyền & Matrix) *@
                    <li class="nav-item">
                        <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Role" ? "active" : "")"
                           href="/admin/role">
                            <i class="bi bi-shield-lock-fill me-2"></i> Phân quyền Matrix
                        </a>
                    </li>

                    @* Nhật ký hệ thống *@
                    <li class="nav-item">
                        <a class="nav-link hdk-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SystemLog" ? "active" : "")"
                           href="/admin/systemlog">
                            <i class="bi bi-journal-text me-2"></i> Audit Log
                        </a>
                    </li>
                }

            </ul>
        </nav>
        <!-- END SIDEBAR -->

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                   -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <main id="hdk-admin-main" class="flex-grow-1 p-4">

            @* ── Giai đoạn 4: SweetAlert2 Toast — data bridge từ TempData ── *@
            @* Các span ẩn mang message; script bên dưới đọc và hiển thị Toast *@
            @if (TempData["Success"] != null)
            {
                <span id="toast-success" class="d-none" data-msg="@TempData["Success"]"></span>
            }
            @if (TempData["Error"] != null)
            {
                <span id="toast-error" class="d-none" data-msg="@TempData["Error"]"></span>
            }
            @if (TempData["Warning"] != null)
            {
                <span id="toast-warning" class="d-none" data-msg="@TempData["Warning"]"></span>
            }
            @if (TempData["Info"] != null)
            {
                <span id="toast-info" class="d-none" data-msg="@TempData["Info"]"></span>
            }

            @RenderBody()
        </main>
        <!-- END MAIN CONTENT -->

    </div><!-- END WRAPPER -->

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- JavaScript                                                         -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Giai đoạn 4: SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <script src="~/admin/js/admin-utils.js" asp-append-version="true"></script>
    <script src="~/admin/js/admin-main.js" asp-append-version="true"></script>

    <script>
        // Sidebar toggle
        document.getElementById('sidebarToggleBtn')?.addEventListener('click', function () {
            document.getElementById('hdk-admin-wrapper').classList.toggle('sidebar-collapsed');
        });

                // ── Giai đoạn 4: SweetAlert2 — Global Toast Handler ──────────────
                // Tự động hiển thị Toast popup góc phải khi có TempData từ server.
                // Hỗ trợ: Success (xanh), Error (đỏ), Warning (vàng), Info (xanh nhạt).
                (function () {
                    const HdkToast = Swal.mixin({
                        toast:             true,
                        position:          'top-end',
                        showConfirmButton: false,
                        timer:             4000,
                        timerProgressBar:  true,
                        showCloseButton:   true,
                        didOpen: (toast) => {
                            toast.addEventListener('mouseenter', Swal.stopTimer);
                            toast.addEventListener('mouseleave', Swal.resumeTimer);
                        }
                    });

                    const checks = [
                        { id: 'toast-success', icon: 'success', title: 'Thành công' },
                        { id: 'toast-error',   icon: 'error',   title: 'Lỗi' },
                        { id: 'toast-warning', icon: 'warning', title: 'Cảnh báo' },
                        { id: 'toast-info',    icon: 'info',    title: 'Thông báo' }
                    ];

                    checks.forEach(({ id, icon, title }) => {
                        const el = document.getElementById(id);
                        if (el) {
                            HdkToast.fire({
                                icon:  icon,
                                title: title,
                                text:  el.dataset.msg
                            });
                        }
                    });
                })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
