@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Gửi lại email xác nhận";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="confirm-wrapper">
    <div class="confirm-card" style="max-width:420px;">
        <div style="font-size:48px;margin-bottom:16px;">📨</div>
        <h2 style="font-size:22px;font-weight:700;color:#1f2937;margin-bottom:8px;">Gửi lại email xác nhận</h2>

        @if (TempData["StatusMessage"] != null)
        {
            <div style="background:#dcfce7;border:1px solid #bbf7d0;border-radius:10px;padding:14px 16px;margin-bottom:20px;color:#15803d;font-size:14px;">
                <i class="bi bi-check-circle me-2"></i>@TempData["StatusMessage"]
            </div>
        }

        <p style="color:#6b7280;font-size:14px;margin-bottom:24px;">
            Nhập email đăng ký để nhận lại link xác nhận.
        </p>

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-floating-hdk">
                <label asp-for="Input.Email">Địa chỉ email</label>
                <i class="bi bi-envelope input-icon"></i>
                <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="invalid-feedback" style="display:block;"></span>
            </div>
            <button type="submit" class="btn-register">
                <i class="bi bi-envelope-arrow-up me-2"></i>GỬI LẠI EMAIL
            </button>
        </form>

        <div style="margin-top:20px;font-size:13px;color:#9ca3af;text-align:center;">
            <a asp-page="./Login" style="color:#ef4444;font-weight:600;text-decoration:none;">← Quay lại đăng nhập</a>
        </div>
    </div>
</div>

<style>
.confirm-wrapper { min-height:calc(100vh - 200px); display:flex; align-items:center; justify-content:center; padding:40px 16px; background:#f5f5f5; }
.confirm-card { background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,.10); padding:40px 36px; text-align:center; width:100%; }
.form-floating-hdk { position:relative; margin-bottom:16px; text-align:left; }
.form-floating-hdk label { font-size:13px; font-weight:600; color:#374151; margin-bottom:6px; display:block; }
.form-floating-hdk .form-control { border:1.5px solid #e5e7eb; border-radius:10px; padding:12px 16px 12px 44px; font-size:14px; width:100%; }
.form-floating-hdk .form-control:focus { border-color:#ef4444; box-shadow:0 0 0 3px rgba(239,68,68,.1); outline:none; }
.form-floating-hdk .input-icon { position:absolute; left:14px; top:50%; transform:translateY(calc(-50% + 14px)); color:#9ca3af; font-size:16px; pointer-events:none; }
.btn-register { width:100%; padding:13px; background:#ef4444; color:#fff; border:none; border-radius:10px; font-weight:700; font-size:15px; cursor:pointer; }
.btn-register:hover { background:#dc2626; }
.invalid-feedback { font-size:12px; color:#dc2626; margin-top:4px; }
</style>
