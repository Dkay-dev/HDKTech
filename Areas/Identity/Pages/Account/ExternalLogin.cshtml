@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Đăng nhập bằng Google";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-card" style="max-width:440px;">
        <div class="auth-header" style="background:linear-gradient(135deg,#4285F4,#34A853);">
            <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:8px;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="28" height="28">
                    <path fill="#FFF" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
                    <path fill="#FFF" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
                    <path fill="#FFF" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
                    <path fill="#FFF" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
                </svg>
                <h2 style="color:#fff;margin:0;font-size:20px;font-weight:700;">Đăng nhập bằng Google</h2>
            </div>
            <p style="color:rgba(255,255,255,0.9);font-size:13px;margin:0;">
                Xác nhận email để đăng nhập bằng tài khoản @Model.ProviderDisplayName
            </p>
        </div>

        <div class="auth-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-hdk">@TempData["ErrorMessage"]</div>
            }

            @{
                var errors = ViewData.ModelState.Values
                    .SelectMany(v => v.Errors)
                    .Select(e => e.ErrorMessage)
                    .ToList();
            }
            @if (errors.Any())
            {
                <div class="alert-hdk">
                    <ul class="mb-0 ps-3">
                        @foreach (var e in errors) { <li>@e</li> }
                    </ul>
                </div>
            }

            <p style="color:#555;font-size:14px;margin-bottom:20px;">
                Google đã cung cấp email bên dưới. Xác nhận để đăng nhập vào hệ thống.
            </p>

            <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                @Html.AntiForgeryToken()

                <div class="form-floating-hdk">
                    <label>Họ tên</label>
                    <i class="bi bi-person input-icon"></i>
                    <input asp-for="Input.FullName" class="form-control" placeholder="Tên của bạn" />
                </div>

                <div class="form-floating-hdk">
                    <label asp-for="Input.Email">Email xác nhận</label>
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Input.Email" class="form-control" placeholder="you@gmail.com" />
                </div>

                <button type="submit" class="btn-register">
                    <i class="bi bi-link-45deg me-2"></i>XÁC NHẬN VÀ ĐĂNG NHẬP
                </button>
            </form>
        </div>
    </div>
</div>

<style>
.auth-wrapper { min-height:calc(100vh - 160px); display:flex; align-items:center; justify-content:center; padding:40px 16px; background:#f5f5f5; }
.auth-card { background:#fff; border-radius:16px; box-shadow:0 8px 40px rgba(0,0,0,.10); width:100%; overflow:hidden; }
.auth-header { padding:28px 32px; text-align:center; }
.auth-body { padding:32px; }
.form-floating-hdk { position:relative; margin-bottom:16px; }
.form-floating-hdk label { font-size:13px; font-weight:600; color:#374151; margin-bottom:6px; display:block; }
.form-floating-hdk .form-control { border:1.5px solid #e5e7eb; border-radius:10px; padding:12px 16px 12px 44px; font-size:14px; }
.form-floating-hdk .form-control:focus { border-color:#4285F4; box-shadow:0 0 0 3px rgba(66,133,244,.12); outline:none; }
.form-floating-hdk .input-icon { position:absolute; left:14px; top:50%; transform:translateY(calc(-50% + 14px)); color:#9ca3af; font-size:16px; pointer-events:none; }
.btn-register { width:100%; padding:13px; background:#4285F4; color:#fff; border:none; border-radius:10px; font-weight:700; font-size:15px; cursor:pointer; }
.btn-register:hover { background:#357ae8; }
.alert-hdk { background:#fef2f2; border:1px solid #fecaca; border-radius:10px; padding:12px 16px; margin-bottom:16px; font-size:13px; color:#dc2626; }
</style>
