@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<style>
.otp-wrapper {
    min-height: calc(100vh - 200px);
    display: flex; align-items: center; justify-content: center;
    padding: 40px 16px; background: #f5f5f5;
}
.otp-card {
    background: #fff; border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0,0,0,.10);
    padding: 48px 40px; text-align: center;
    max-width: 480px; width: 100%;
}
.key-icon {
    width: 90px; height: 90px; border-radius: 50%;
    background: linear-gradient(135deg, #dbeafe, #bfdbfe);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px; font-size: 40px;
}
.otp-card h2 { font-size: 24px; font-weight: 700; color: #1f2937; margin-bottom: 8px; }
.otp-desc { color: #6b7280; font-size: 14px; line-height: 1.7; margin-bottom: 6px; }
.email-badge {
    display: inline-block;
    background: #eff6ff; border: 1.5px solid #bfdbfe;
    color: #2563eb; font-weight: 700; font-size: 14px;
    padding: 6px 18px; border-radius: 8px; margin: 4px 0 24px;
    word-break: break-all;
}
.otp-input {
    width: 100%; text-align: center;
    font-size: 32px; font-weight: 800; letter-spacing: 14px;
    font-family: monospace;
    border: 2px solid #e5e7eb; border-radius: 12px;
    padding: 14px 12px; outline: none;
    transition: border-color .2s;
}
.otp-input:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.15); }
.form-control-hdk {
    width: 100%; padding: 12px 16px;
    border: 2px solid #e5e7eb; border-radius: 10px;
    font-size: 15px; outline: none; transition: border-color .2s;
}
.form-control-hdk:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.15); }
.btn-confirm {
    width: 100%; padding: 14px;
    background: #2563eb; color: #fff;
    border: none; border-radius: 10px;
    font-size: 15px; font-weight: 700;
    cursor: pointer; transition: background .2s;
    margin-top: 20px;
}
.btn-confirm:hover { background: #1d4ed8; }
.alert-danger-custom {
    background: #fef2f2; border: 1px solid #fecaca;
    color: #b91c1c; border-radius: 10px;
    padding: 12px 16px; font-size: 14px; margin-bottom: 16px;
    text-align: left; display: flex; align-items: flex-start; gap: 8px;
}
.alert-success-custom {
    background: #f0fdf4; border: 1px solid #bbf7d0;
    color: #15803d; border-radius: 10px;
    padding: 16px; font-size: 15px; margin-bottom: 16px;
    text-align: center;
}
.resend-row { margin-top: 20px; font-size: 13px; color: #6b7280; }
.divider { border: none; border-top: 1px solid #f0f0f0; margin: 24px 0; }
</style>

<div class="otp-wrapper">
    <div class="otp-card">

        @if (Model.ResetSuccess)
        {
            <div style="text-align:center;">
                <div style="width:80px;height:80px;border-radius:50%;background:#dcfce7;
                            display:flex;align-items:center;justify-content:center;
                            margin:0 auto 20px;font-size:36px;">✅</div>
                <h2 style="color:#15803d;">Đặt lại thành công!</h2>
                <p style="color:#6b7280;margin:12px 0 28px;">
                    Mật khẩu của bạn đã được cập nhật. Bạn có thể đăng nhập ngay bây giờ.
                </p>
                <a asp-page="./Login"
                   style="display:inline-flex;align-items:center;gap:8px;
                          background:#2563eb;color:#fff;padding:13px 32px;
                          border-radius:10px;text-decoration:none;font-weight:700;">
                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập ngay
                </a>
            </div>
        }
        else
        {
            <div class="key-icon">🔑</div>
            <h2>Đặt lại mật khẩu</h2>
            <p class="otp-desc">Nhập mã OTP đã gửi đến:</p>
            <div class="email-badge">@Model.Email</div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert-danger-custom">
                    <i class="bi bi-exclamation-circle-fill mt-1"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            @if (Model.ResendSuccess)
            {
                <div class="alert-success-custom">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    Đã gửi lại mã OTP mới! Vui lòng kiểm tra email.
                </div>
            }

            <form method="post">
                <input type="hidden" asp-for="Email" />

                <div asp-validation-summary="ModelOnly" class="alert-danger-custom" style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>

                <div class="mb-3">
                    <input asp-for="Otp"
                           class="otp-input"
                           maxlength="6"
                           inputmode="numeric"
                           pattern="\d{6}"
                           placeholder="······"
                           autocomplete="one-time-code"
                           autofocus />
                    <span asp-validation-for="Otp" class="text-danger small d-block mt-1"></span>
                </div>

                <hr class="divider" />

                <div class="mb-3" style="text-align:left;">
                    <label class="form-label fw-semibold" style="font-size:14px;color:#374151;">
                        Mật khẩu mới
                    </label>
                    <input asp-for="Password"
                           class="form-control-hdk"
                           type="password"
                           autocomplete="new-password"
                           placeholder="Tối thiểu 6 ký tự" />
                    <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-2" style="text-align:left;">
                    <label class="form-label fw-semibold" style="font-size:14px;color:#374151;">
                        Xác nhận mật khẩu
                    </label>
                    <input asp-for="ConfirmPassword"
                           class="form-control-hdk"
                           type="password"
                           autocomplete="new-password"
                           placeholder="Nhập lại mật khẩu" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                </div>

                <button type="submit" class="btn-confirm">
                    <i class="bi bi-shield-lock me-2"></i>Xác nhận & Đặt lại mật khẩu
                </button>

                <p style="font-size:12px;color:#9ca3af;margin-top:12px;">
                    <i class="bi bi-clock me-1"></i>Mã OTP có hiệu lực trong 15 phút.
                </p>
            </form>

            <div class="resend-row">
                Chưa nhận được mã?
                <form method="post" asp-page-handler="Resend" style="display:inline;">
                    <input type="hidden" asp-for="Email" />
                    <button type="submit"
                            style="background:none;border:none;color:#2563eb;font-weight:700;
                                   cursor:pointer;padding:0;font-size:13px;text-decoration:underline;">
                        Gửi lại
                    </button>
                </form>
                &nbsp;·&nbsp;
                <a asp-page="./ForgotPassword" style="color:#6b7280;">Thử email khác</a>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('.otp-input')?.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 6);
        });
    </script>
}
