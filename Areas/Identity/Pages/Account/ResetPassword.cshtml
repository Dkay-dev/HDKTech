@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<style>
.reset-wrapper {
    min-height: calc(100vh - 200px);
    display: flex; align-items: center; justify-content: center;
    padding: 40px 16px; background: #f5f5f5;
}
.reset-card {
    background: #fff; border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0,0,0,.10);
    padding: 48px 40px;
    max-width: 460px; width: 100%;
}
.reset-card h2 {
    font-size: 22px; font-weight: 700; color: #1f2937;
    margin-bottom: 6px; text-align: center;
}
.reset-sub {
    text-align: center; color: #6b7280; font-size: 14px; margin-bottom: 28px;
}
.form-label-hdk { font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 6px; }
.form-control-hdk {
    width: 100%; padding: 12px 16px;
    border: 2px solid #e5e7eb; border-radius: 10px;
    font-size: 15px; outline: none; transition: border-color .2s;
}
.form-control-hdk:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.15); }
.btn-reset {
    width: 100%; padding: 14px;
    background: #2563eb; color: #fff;
    border: none; border-radius: 10px;
    font-size: 15px; font-weight: 700;
    cursor: pointer; transition: background .2s;
    margin-top: 8px;
}
.btn-reset:hover { background: #1d4ed8; }
</style>

<div class="reset-wrapper">
    <div class="reset-card">
        <div style="text-align:center;margin-bottom:24px;">
            <div style="width:70px;height:70px;border-radius:50%;
                        background:linear-gradient(135deg,#dbeafe,#bfdbfe);
                        display:inline-flex;align-items:center;justify-content:center;font-size:32px;">
                🔐
            </div>
        </div>
        <h2>Đặt lại mật khẩu</h2>
        <p class="reset-sub">Nhập mật khẩu mới cho tài khoản của bạn.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div class="mb-3">
                <label class="form-label-hdk">Email</label>
                <input asp-for="Input.Email"
                       class="form-control-hdk"
                       autocomplete="username"
                       placeholder="email@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label-hdk">Mật khẩu mới</label>
                <input asp-for="Input.Password"
                       class="form-control-hdk"
                       type="password"
                       autocomplete="new-password"
                       placeholder="Tối thiểu 6 ký tự" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label-hdk">Xác nhận mật khẩu</label>
                <input asp-for="Input.ConfirmPassword"
                       class="form-control-hdk"
                       type="password"
                       autocomplete="new-password"
                       placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-reset">
                <i class="bi bi-shield-lock me-2"></i>Đặt lại mật khẩu
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
