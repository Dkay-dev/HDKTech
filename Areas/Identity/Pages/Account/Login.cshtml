@* ✅ Fix #1: Override trang Login của Identity để hỗ trợ redirect theo Role
   Admin/WarehouseStaff  → /Admin/Dashboard
   Customer (mặc định) → Trang chủ hoặc returnUrl *@

@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/client/css/login.css" asp-append-version="true" />
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">

            <!-- Card đăng nhập -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">

                    <!-- Logo / Tiêu đề -->
                    <div class="text-center mb-4">
                        <h2 class="fw-bold mb-1">
                            <span style="color:#e31837;">HDK</span><span>Tech</span>
                        </h2>
                        <p class="text-muted small">Đăng nhập vào tài khoản của bạn</p>
                    </div>

                    <!-- Thông báo lỗi chung -->
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-sm small py-2">
                            <i class="bi bi-exclamation-circle me-1"></i>@Model.ErrorMessage
                        </div>
                    }

                    <!-- Form đăng nhập -->
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label fw-semibold small">Email</label>
                            <input asp-for="Input.Email"
                                   class="form-control"
                                   autocomplete="username"
                                   placeholder="email@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- Mật khẩu -->
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label fw-semibold small">Mật khẩu</label>
                            <input asp-for="Input.Password"
                                   class="form-control"
                                   autocomplete="current-password"
                                   type="password"
                                   placeholder="••••••••" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- Ghi nhớ đăng nhập -->
                        <div class="mb-3 form-check">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label small">Ghi nhớ đăng nhập</label>
                        </div>

                        <!-- Nút đăng nhập -->
                        <button type="submit" class="btn btn-danger w-100 fw-bold py-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                        </button>
                    </form>

                    <!-- Link phụ -->
                    <div class="mt-3 text-center">
                        <a asp-page="./ForgotPassword" class="text-muted small text-decoration-none">
                            Quên mật khẩu?
                        </a>
                    </div>
                    <hr class="my-3" />
                    <div class="text-center small">
                        Chưa có tài khoản?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                           class="text-danger fw-bold text-decoration-none">Đăng ký ngay</a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
