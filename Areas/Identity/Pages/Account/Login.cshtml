@* ✅ Fix #1: Override trang Login của Identity để hỗ trợ redirect theo Role
   Admin / Manager / Staff  → /Admin/Dashboard
   Customer (mặc định)      → Trang chủ hoặc returnUrl *@

@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/client/css/login.css" asp-append-version="true" />
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">

            <!-- Card đăng nhập -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">

                    <!-- Logo / Tiêu đề -->
                    <div class="text-center mb-4">
                        <h2 class="fw-bold mb-1">
                            <span style="color:#e31837;">HDK</span><span>Tech</span>
                        </h2>
                        <p class="text-muted small">Đăng nhập vào tài khoản của bạn</p>
                    </div>

                    <!-- Thông báo lỗi chung -->
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-sm small py-2">
                            <i class="bi bi-exclamation-circle me-1"></i>@Model.ErrorMessage
                        </div>
                    }

                    <!-- Đăng nhập bằng Google -->
                    @if (Model.ExternalLogins?.Any() == true)
                    {
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mb-3">
                            @foreach (var provider in Model.ExternalLogins)
                            {
                                if (provider.Name == "Google")
                                {
                                    <button type="submit" name="provider" value="@provider.Name"
                                            class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2 py-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20">
                                            <path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/>
                                            <path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/>
                                            <path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/>
                                            <path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>
                                        </svg>
                                        <span class="fw-semibold small">Đăng nhập bằng Google</span>
                                    </button>
                                }
                            }
                        </form>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <hr class="flex-fill m-0" /><span class="text-muted small">hoặc đăng nhập bằng email</span><hr class="flex-fill m-0" />
                        </div>
                    }

                    <!-- Form đăng nhập -->
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label fw-semibold small">Email</label>
                            <input asp-for="Input.Email"
                                   class="form-control"
                                   autocomplete="username"
                                   placeholder="email@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- Mật khẩu -->
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label fw-semibold small">Mật khẩu</label>
                            <input asp-for="Input.Password"
                                   class="form-control"
                                   autocomplete="current-password"
                                   type="password"
                                   placeholder="••••••••" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- Ghi nhớ đăng nhập -->
                        <div class="mb-3 form-check">
                            <input asp-for="Input.RememberMe" class="form-check-input" />
                            <label asp-for="Input.RememberMe" class="form-check-label small">Ghi nhớ đăng nhập</label>
                        </div>

                        <!-- Nút đăng nhập -->
                        <button type="submit" class="btn btn-danger w-100 fw-bold py-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                        </button>
                    </form>

                    <!-- Link phụ -->
                    <div class="mt-3 text-center">
                        <a asp-page="./ForgotPassword" class="text-muted small text-decoration-none">
                            Quên mật khẩu?
                        </a>
                    </div>
                    <hr class="my-3" />
                    <div class="text-center small">
                        Chưa có tài khoản?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                           class="text-danger fw-bold text-decoration-none">Đăng ký ngay</a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
