@using Microsoft.AspNetCore.Identity

@inject SignInManager<NguoiDung> SignInManager
@inject UserManager<NguoiDung> UserManager

<ul class="navbar-nav">
    <li class="nav-item">
        <a class="nav-link text-light" href="#">
        <span class="badge bg-primary">0</span>
        <i class="bi bi-cart"></i>
        </a>
    </li>
    
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a id="manage" class="nav-link text-light" asp-area="Identity" asp-page="/Account/Manage/Index" title="Quản lý tài khoản">Xin chào @UserManager.GetUserName(User)!</a>
        </li>
        <li class="nav-item">
            <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button id="logout" type="submit" class="nav-link btn-success text-light border-0">Đăng xuất</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-light" id="register" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-light" id="login" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
        </li>
    }
</ul>