@* ═══════════════════════════════════════════════════════════════════════
   _ProductCard.cshtml — HDKTech Definitive Product Card
   ─────────────────────────────────────────────────────────────────────
   Model     : HDKTech.Models.Product
   Requires  : ~/css/components/product-card.css (link once in _Layout)
               ImageHelper.GetImagePath()
               addToCartAjax() from ~/js/cart.js
   Usage     : @await Html.PartialAsync("_ProductCard", product)
               @await Html.PartialAsync("_ProductCard", product, new ViewDataDictionary(ViewData) { { "ShowCompare", true } })

   FIX LOG:
   - Removed onclick="goToDetail()" from <article> wrapper (was firing on all clicks)
   - Removed nested duplicate <article> tags
   - Image area no longer navigates — it's a plain div
   - Only pc__name-link navigates to Details
   - Hover action buttons are top-level z-index and stopPropagation-safe
   ═══════════════════════════════════════════════════════════════════════ *@
@model HDKTech.Models.Product
@using HDKTech.Utils

@{
    // ── State Detection (post-refactor: giá & flash sale đi qua Variant/Promotion) ──
    var defaultVariant = Model.DefaultVariant;
    var displayPrice   = Model.DisplayPrice ?? 0m;
    var originalPrice  = displayPrice;
    var listPrice      = Model.DisplayListPrice;
    var hasDiscount    = listPrice.HasValue && listPrice > displayPrice;
    var discountPct    = defaultVariant?.DiscountPercent ?? 0;

    // Flash sale info đã chuyển sang bảng Promotion → ViewBag có thể inject endTime
    var isFlashSale    = (ViewBag.IsFlashSale as bool?) ?? false;
    var endTimeIso     = ViewBag.FlashSaleEndTime as string ?? "";

    // ── Image ──────────────────────────────────────────────────────────
    var rawImg = Model.Images?.FirstOrDefault(h => h.IsDefault)?.ImageUrl
               ?? Model.Images?.FirstOrDefault()?.ImageUrl
               ?? "no-image.png";
    var imgPath = ImageHelper.GetImagePath(rawImg, Model.Category?.Name);

    // ── Specs preview (top 2 key specs from pipe-separated string) ─────
    var specsPreview = (Model.Specifications ?? "")
        .Split(new[] { '|', '\n' }, StringSplitOptions.RemoveEmptyEntries)
        .Select(s => s.Trim())
        .Where(s => s.Contains(':'))
        .Take(2)
        .Select(s =>
        {
            var parts = s.Split(':', 2);
            return new { Key = parts[0].Trim(), Val = parts.Length > 1 ? parts[1].Trim() : "" };
        })
        .ToList();

    // ── Inventory stock for urgency signal (sum across variants) ──────
    var stock = Model.Variants?.SelectMany(v => v.Inventories ?? Enumerable.Empty<HDKTech.Models.Inventory>())
                               .Sum(i => i.Quantity) ?? 0;
    var showStockUrgency = stock > 0 && stock <= 5;

    // ── Rating (real avg from Reviews) ─────────────────────────────────
    var reviewCount = Model.Reviews?.Count ?? 0;
    var avgRating = reviewCount > 0
        ? Math.Round(Model.Reviews!.Average(r => r.Rating), 1)
        : 0.0;
    var showRating = reviewCount > 0;

    // ── Brand label ────────────────────────────────────────────────────
    var brandName = Model.Brand?.Name ?? "";

    // ── Options passed from parent view ───────────────────────────────
    var showCompare = ViewData["ShowCompare"] as bool? ?? false;

    // ── CSS state modifier ─────────────────────────────────────────────
    var cardMod = isFlashSale ? "pc--flash" : "";

    // ── Detail URL ─────────────────────────────────────────────────────
    var detailUrl = $"/Product/Details/{Model.Id}";
}


<article class="pc @cardMod" data-product-id="@Model.Id" role="listitem">

    @* ── IMAGE ZONE — plain div, no navigation on click ──────────────── *@
    <div class="pc__image-zone">

        @* Non-navigating image container *@
        <div class="pc__img-wrapper">
            <img src="@imgPath"
                 alt="@Model.Name"
                 class="pc__img"
                 loading="lazy"
                 decoding="async"
                 onerror="this.onerror=null;this.src='/images/products/no-image.png';" />
        </div>

        @* ── Badges overlay ──────────────────────────────────────────── *@
        <div class="pc__badges">
            @if (isFlashSale)
            {
                <span class="pc__badge pc__badge--flash" aria-label="Flash Sale đang diễn ra">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true"><path d="M6 1L2 6h3l-1 3L9 4H6L6 1z" /></svg>
                    FLASH
                </span>
            }
            @if (discountPct > 0)
            {
                <span class="pc__badge pc__badge--discount" aria-label="Giảm @discountPct phần trăm">
                    -@discountPct%
                </span>
            }
            @if (!isFlashSale && discountPct == 0)
            {
                <span class="pc__badge pc__badge--new">MỚI</span>
            }
        </div>

        @* ── Flash countdown (only when flash sale active) ─────────────── *@
        @if (isFlashSale && !string.IsNullOrEmpty(endTimeIso))
        {
            <div class="pc__countdown" data-end="@endTimeIso" aria-live="polite" aria-label="Thời gian còn lại của Flash Sale">
                <span class="pc__cd-unit" aria-hidden="true">
                    <span class="pc__cd-num" data-unit="h">00</span>
                    <span class="pc__cd-label">giờ</span>
                </span>
                <span class="pc__cd-sep" aria-hidden="true">:</span>
                <span class="pc__cd-unit" aria-hidden="true">
                    <span class="pc__cd-num" data-unit="m">00</span>
                    <span class="pc__cd-label">phút</span>
                </span>
                <span class="pc__cd-sep" aria-hidden="true">:</span>
                <span class="pc__cd-unit" aria-hidden="true">
                    <span class="pc__cd-num" data-unit="s">00</span>
                    <span class="pc__cd-label">giây</span>
                </span>
            </div>
        }

        @* ── Hover action buttons — stopPropagation prevents any parent nav ─ *@
        <div class="pc__hover-actions" aria-hidden="true">
            <button type="button"
                    class="pc__action-btn pc__action-btn--cart"
                    onclick="event.stopPropagation(); addToCartAjax(@Model.Id, '@Html.Raw(Model.Name.Replace("'", "\\'"))')"
                    aria-label="Thêm @Model.Name vào giỏ hàng">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="9" cy="21" r="1" />
                    <circle cx="20" cy="21" r="1" />
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                </svg>
                Thêm giỏ hàng
            </button>
            @if (showCompare)
            {
                <button type="button"
                        class="pc__action-btn pc__action-btn--compare"
                        onclick="event.stopPropagation(); addToCompare(@Model.Id, '@Html.Raw(Model.Name.Replace("'", "\\'"))')"
                        aria-label="So sánh @Model.Name">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                    </svg>
                    So sánh
                </button>
            }
        </div>
    </div>

    @* ── BODY ZONE ────────────────────────────────────────────────────── *@
    <div class="pc__body">

        @* Brand label — no link, no cursor pointer *@
        @if (!string.IsNullOrEmpty(brandName))
        {
            <span class="pc__brand" aria-label="Thương hiệu @brandName">@brandName</span>
        }

        @* Product name — THE ONLY element that navigates to Details *@
        <h3 class="pc__name">
            <a href="@detailUrl" class="pc__name-link">@Model.Name</a>
        </h3>

        @* Specs preview — plain text, no navigation *@
        @if (specsPreview.Any())
        {
            <ul class="pc__specs" aria-label="Thông số nhanh">
                @foreach (var spec in specsPreview)
                {
                    <li class="pc__spec-item">
                        <span class="pc__spec-key">@spec.Key</span>
                        <span class="pc__spec-val">@spec.Val</span>
                    </li>
                }
            </ul>
        }

        @* Rating row *@
        @if (showRating)
        {
            <div class="pc__rating" aria-label="Đánh giá @avgRating trên 5 sao từ @reviewCount lượt">
                <div class="pc__stars" role="img" aria-hidden="true">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="pc__star @(i <= Math.Round(avgRating) ? "pc__star--on" : "")">&#9733;</span>
                    }
                </div>
                <span class="pc__rating-num">@avgRating</span>
                <span class="pc__rating-count">(@reviewCount)</span>
            </div>
        }

        @* Price zone *@
        <div class="pc__price-zone">
            @if (isFlashSale)
            {
                <div class="pc__price-flash">
                    <span class="pc__price-current pc__price-current--flash">
                        @displayPrice.ToString("N0")₫
                    </span>
                    <span class="pc__price-original">@originalPrice.ToString("N0")₫</span>
                </div>
            }
            else
            {
                <div class="pc__price-normal">
                    <span class="pc__price-current">@displayPrice.ToString("N0")₫</span>
                    @if (hasDiscount)
                    {
                        <span class="pc__price-original">@listPrice!.Value.ToString("N0")₫</span>
                    }
                </div>
            }
        </div>

        @* Stock urgency signal — only show when genuinely low *@
        @if (showStockUrgency)
        {
            <p class="pc__stock-urgency" role="status" aria-live="polite">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true"><circle cx="5" cy="5" r="5" /></svg>
                Chỉ còn <strong>@stock</strong> sản phẩm
            </p>
        }

    </div>
</article>

@* Countdown được khởi động bởi home.js (initFlashSale) — không cần inline script *@
