@*
/* ═══════════════════════════════════════════════════════════════════════════════
   HDKTech Layout - Red & White Theme với SpaceX Typography
   ═══════════════════════════════════════════════════════════════════════════════ */
*@

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HDKTech</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/product-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/spacex-colors.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- ╔════════════════════════════════════════════════════════════════╗ -->
    <!-- ║ HEADER TIER 1: Logo | Nav | Hotline | Auth | Cart            ║ -->
    <!-- ╚════════════════════════════════════════════════════════════════╝ -->
    <header class="hdk-tier1-header sticky-top">
        <div class="container-fluid">
            <div class="hdk-tier1-content d-flex align-items-center justify-content-between px-3 py-3 gap-3">

                <!-- ═══ LEFT SECTION: Logo + Nav Links ═══ -->
                <div class="hdk-tier1-left d-flex align-items-center gap-4 flex-shrink-0">

                    <!-- LOGO -->
                    <a href="/" class="text-decoration-none d-flex align-items-center">
                        <div class="hdk-logo">
                            <span class="hdk-logo-hdk">HDK</span><span class="hdk-logo-tech">Tech</span>
                        </div>
                    </a>

                    <!-- NAVIGATION LINKS -->
                    <div class="hdk-nav-links d-none d-lg-flex gap-4 align-items-center ms-2">
                        <a asp-area="" asp-controller="Home" asp-action="About" title="Về chúng tôi" class="nav-link-item">Về chúng tôi</a>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" title="Chính sách" class="nav-link-item">Chính sách</a>
                        <a asp-area="" asp-controller="Home" asp-action="Hotline" title="Liên hệ" class="nav-link-item">Liên hệ</a>
                    </div>
                </div>

                <!-- ═══ RIGHT SECTION: Auth + Cart ═══ -->
                <div class="hdk-tier1-right d-flex align-items-center gap-3 flex-shrink-0">

                    <!-- AUTH LINKS -->
                    <div class="hdk-auth-links d-none d-lg-flex gap-0 align-items-center flex-shrink-0">
                        <partial name="_LoginPartial" />
                    </div>

                    <!-- CART ICON -->
                    <a asp-area="" asp-controller="Cart" asp-action="Index" class="hdk-cart-container d-inline-flex align-items-center justify-content-center position-relative flex-shrink-0">
                        <i class="bi bi-bag-fill hdk-cart-icon"></i>
                        @await Component.InvokeAsync("CartSummary")
                    </a>

                    <!-- MOBILE MENU TOGGLE -->
                    <button class="btn btn-link p-0 flex-shrink-0" type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu" aria-expanded="false" style="color: #333;">
                        <i class="bi bi-list fs-5"></i>
                    </button>
                </div>
            </div>

            <!-- MOBILE MENU -->
            <div class="collapse d-lg-none" id="mobileMenu">
                <div class="pb-3 border-top" style="border-color: #e0e0e0 !important;">
                    <a asp-area="" asp-controller="Home" asp-action="About" class="d-block" style="color: #333; text-decoration: none; font-size: 0.85rem; text-transform: uppercase; font-weight: 600; padding: 8px 0;">Về chúng tôi</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="d-block" style="color: #333; text-decoration: none; font-size: 0.85rem; text-transform: uppercase; font-weight: 600; padding: 8px 0;">Chính sách</a>
                    <a asp-area="" asp-controller="Home" asp-action="Hotline" class="d-block" style="color: #333; text-decoration: none; font-size: 0.85rem; text-transform: uppercase; font-weight: 600; padding: 8px 0;">Liên hệ</a>
                </div>
            </div>
        </div>
    </header>

    <!-- ╔════════════════════════════════════════════════════════════════╗ -->
    <!-- ║ HEADER TIER 2: Category Menu | Search Bar                       ║ -->
    <!-- ╚════════════════════════════════════════════════════════════════╝ -->
    <header class="hdk-tier2-header sticky-top" style="top: 73px;">
        <div class="container-fluid">
            <div class="row align-items-center px-3 py-3 gx-3">

                <!-- ═══ CATEGORY MENU BUTTON ═══ -->
                <div class="col-auto">
                    <div class="dropdown">
                        <button class="hdk-category-btn dropdown-toggle" type="button" id="categoryDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-list"></i>
                            <span class="ms-2 d-none d-md-inline">DANH MỤC</span>
                            <i class="bi bi-chevron-down ms-2 d-none d-md-inline"></i>
                        </button>
                        <div class="dropdown-menu hdk-dropdown-menu" aria-labelledby="categoryDropdown">
                            @await Component.InvokeAsync("Categories")
                        </div>
                    </div>
                </div>

                <!-- ═══ SEARCH BAR ═══ -->
                <div class="col">
                    <form asp-area="" asp-controller="Product" asp-action="Search" method="get" class="w-100">
                        <div class="hdk-search-container">
                            <input type="text"
                                   class="hdk-search-input"
                                   name="keyword"
                                   placeholder="Tìm laptop, linh kiện, phụ kiện..."
                                   aria-label="Tìm kiếm sản phẩm">
                            <button type="submit" class="hdk-search-btn" title="Tìm kiếm">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </header>

    <!-- Toast Container -->
    <div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1040;"></div>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- MAIN CONTENT AREA -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <main class="content-wrapper" style="margin-top: 0; padding: 0; background: #f5f5f5;">
        <div class="container-fluid" style="padding: 0;">
            @RenderBody()
        </div>
    </main>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- FOOTER -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <footer class="hdk-footer-pro">
        <div class="container">
            <div class="row g-4">
                <!-- Brand Column -->
                <div class="col-lg-4 col-md-6">
                    <div class="mb-3">
                        <div class="hdk-logo" style="font-size: 1.4rem;">
                            <span class="hdk-logo-hdk">HDK</span><span class="hdk-logo-tech">Tech</span>
                        </div>
                    </div>
                    <p style="font-size: 0.9rem; color: #a0aec0; line-height: 1.6; margin-bottom: 16px;">
                        Chuyên cung cấp laptop, linh kiện máy tính chính hãng với giá tốt nhất thị trường. Cam kết 100% sản phẩm chính hãng, bảo hành uy tín.
                    </p>
                    <div class="d-flex gap-2">
                        <a href="#" class="btn btn-sm d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; background: #d32f2f; color: white; border-radius: 50%;">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="btn btn-sm d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; background: #d32f2f; color: white; border-radius: 50%;">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="#" class="btn btn-sm d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; background: #d32f2f; color: white; border-radius: 50%;">
                            <i class="bi bi-youtube"></i>
                        </a>
                    </div>
                </div>

                <!-- About Column -->
                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="text-uppercase fw-bold mb-3" style="color: #d32f2f; font-size: 0.85rem; letter-spacing: 1px;">Về chúng tôi</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="About" class="text-decoration-none" style="color: #a0aec0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.3px;">Giới thiệu</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #a0aec0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.3px;">Tin tức</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #a0aec0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.3px;">Tuyển dụng</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Hotline" class="text-decoration-none" style="color: #a0aec0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.3px;">Liên hệ</a></li>
                    </ul>
                </div>

                <!-- Support Column -->
                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="text-uppercase fw-bold mb-3" style="color: #d32f2f; font-size: 0.85rem; letter-spacing: 1px;">Hỗ trợ</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none" style="color: #a0aec0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.3px;">Chính sách bảo hành</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none" style="color: #a0aec0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.3px;">Chính sách đổi trả</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none" style="color: #a0aec0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.3px;">Hướng dẫn mua hàng</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none" style="color: #a0aec0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.3px;">Phương thức thanh toán</a></li>
                    </ul>
                </div>

                <!-- Contact Column -->
                <div class="col-lg-4 col-md-6">
                    <h6 class="text-uppercase fw-bold mb-3" style="color: #d32f2f; font-size: 0.85rem; letter-spacing: 1px;">Liên hệ</h6>
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div class="d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; min-width: 32px; background: #d32f2f; color: white; border-radius: 6px;">
                            <i class="bi bi-geo-alt-fill" style="font-size: 0.9rem;"></i>
                        </div>
                        <div>
                            <small class="d-block text-uppercase" style="color: #718096; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.5px;">Địa chỉ</small>
                            <span style="color: #a0aec0; font-size: 0.85rem;">123 Đường ABC, Quận 1, TP.HCM</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div class="d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; min-width: 32px; background: #d32f2f; color: white; border-radius: 6px;">
                            <i class="bi bi-telephone-fill" style="font-size: 0.9rem;"></i>
                        </div>
                        <div>
                            <small class="d-block text-uppercase" style="color: #718096; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.5px;">Hotline</small>
                            <a href="tel:1900123456" class="text-decoration-none" style="color: #d32f2f; font-size: 0.95rem; font-weight: 600;">1900.123.456</a>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3">
                        <div class="d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; min-width: 32px; background: #d32f2f; color: white; border-radius: 6px;">
                            <i class="bi bi-envelope-fill" style="font-size: 0.9rem;"></i>
                        </div>
                        <div>
                            <small class="d-block text-uppercase" style="color: #718096; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.5px;">Email</small>
                            <a href="mailto:support@hdktech.vn" class="text-decoration-none" style="color: #d32f2f; font-size: 0.85rem;">support@hdktech.vn</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bottom -->
            <div class="row mt-4 pt-4" style="border-top: 1px solid rgba(255,255,255,0.1);">
                <div class="col-12 text-center">
                    <p style="color: #718096; font-size: 0.8rem; margin-bottom: 4px;">
                        &copy; 2026 <a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none" style="color: #d32f2f;">HDKTech</a>. Tất cả các quyền được bảo lưu.
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/image-fallback.js"></script>
    <script src="~/js/cart.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
