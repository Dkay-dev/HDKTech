@model List<Product>

@{
    ViewData["Title"] = $"Kết quả tìm kiếm: {ViewBag.Keyword}";
    var currentSort = ViewBag.CurrentSort as string ?? "featured";
}

<link rel="stylesheet" href="~/css/pages/category.css" />

<div class="container-fluid my-4 px-lg-2">
    <!-- Filter Section -->
    <div class="filter-section bg-white p-3 rounded-3 shadow-sm mb-4 border-light">
        <form asp-action="Search" method="get" id="filterForm" class="w-100">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted small"><i class="bi bi-house-fill me-1"></i>Trang chủ</a></li>
                    <li class="breadcrumb-item active small" aria-current="page">Kết quả tìm kiếm: <strong>@ViewBag.Keyword</strong></li>
                </ol>
            </nav>

            <input type="hidden" name="keyword" value="@ViewBag.Keyword" />

            <div class="d-flex flex-wrap gap-2 mb-3">
                <!-- Tình trạng -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-check-circle me-1"></i> Tình trạng
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&status=1&sortBy=@currentSort">Còn hàng</a></li>
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&status=0&sortBy=@currentSort">Hết hàng</a></li>
                    </ul>
                </div>

                <!-- Giá -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-tag me-1"></i> Giá
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&minPrice=0&maxPrice=5000000&sortBy=@currentSort">Dưới 5 triệu</a></li>
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&minPrice=5000000&maxPrice=10000000&sortBy=@currentSort">5 - 10 triệu</a></li>
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&minPrice=10000000&maxPrice=20000000&sortBy=@currentSort">10 - 20 triệu</a></li>
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&minPrice=20000000&maxPrice=999999999&sortBy=@currentSort">Trên 20 triệu</a></li>
                    </ul>
                </div>

                <!-- Hãng -->
                @if (ViewBag.Brands != null && ((List<string>)ViewBag.Brands).Any())
                {
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-building me-1"></i> Hãng
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var brand in ((List<string>)ViewBag.Brands).Take(10))
                            {
                                <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&brandId=@brand.GetHashCode()&sortBy=@currentSort">@brand</a></li>
                            }
                        </ul>
                    </div>
                }
            </div>

            <!-- Sắp xếp -->
            <div class="d-flex justify-content-end border-top pt-3">
                <div class="sort-wrapper border rounded-2 px-3 py-1 bg-light">
                    <span class="small text-muted me-1">
                        <i class="bi bi-sort-down"></i> Xếp theo:
                    </span>
                    <select name="sortBy" class="border-0 bg-transparent fw-bold small sort-select shadow-none" style="cursor:pointer; outline:none;" onchange="document.getElementById('filterForm').submit();">
                        @if (currentSort == "featured")
                        {
                            <option value="featured" selected>Nổi bật</option>
                        }
                        else
                        {
                            <option value="featured">Nổi bật</option>
                        }
                        @if (currentSort == "name_asc")
                        {
                            <option value="name_asc" selected>Tên từ A-Z</option>
                        }
                        else
                        {
                            <option value="name_asc">Tên từ A-Z</option>
                        }
                        @if (currentSort == "name_desc")
                        {
                            <option value="name_desc" selected>Tên từ Z-A</option>
                        }
                        else
                        {
                            <option value="name_desc">Tên từ Z-A</option>
                        }
                        @if (currentSort == "price_asc")
                        {
                            <option value="price_asc" selected>Giá tăng dần</option>
                        }
                        else
                        {
                            <option value="price_asc">Giá tăng dần</option>
                        }
                        @if (currentSort == "price_desc")
                        {
                            <option value="price_desc" selected>Giá giảm dần</option>
                        }
                        else
                        {
                            <option value="price_desc">Giá giảm dần</option>
                        }
                        @if (currentSort == "new")
                        {
                            <option value="new" selected>Mới nhất</option>
                        }
                        else
                        {
                            <option value="new">Mới nhất</option>
                        }
                    </select>
                </div>
            </div>
        </form>
    </div>

    <div class="pc-grid">
        @foreach (var item in Model)
        {
            @await Html.PartialAsync("_ProductCard", item, new ViewDataDictionary(ViewData) { { "ShowCompare", true } })
        }
    </div>


