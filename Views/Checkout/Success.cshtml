@model HDKTech.Models.Order
@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
}

<style>
    .success-wrapper {
        max-width: 680px;
        margin: 48px auto;
        padding: 0 16px;
    }

    .success-header {
        text-align: center;
        margin-bottom: 32px;
    }

    .success-icon {
        width: 72px;
        height: 72px;
        background: #e8f5e9;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

        .success-icon i {
            font-size: 36px;
            color: #2e7d32;
        }

    .success-header h2 {
        font-size: 26px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 6px;
    }

    .success-header p {
        color: #666;
        font-size: 15px;
    }

    .order-code-badge {
        display: inline-block;
        background: #fff3f3;
        border: 1.5px solid #e53935;
        color: #e53935;
        font-weight: 700;
        font-size: 15px;
        padding: 6px 18px;
        border-radius: 8px;
        letter-spacing: 0.5px;
        margin-top: 8px;
    }

    .info-card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 16px;
    }

        .info-card h6 {
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #999;
            margin-bottom: 16px;
            padding-bottom: 10px;
            border-bottom: 1px solid #f0f0f0;
        }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 6px 0;
        font-size: 14px;
    }

        .info-row .label {
            color: #888;
            min-width: 140px;
        }

        .info-row .value {
            font-weight: 500;
            color: #1a1a1a;
            text-align: right;
        }

    .product-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f5f5f5;
        font-size: 14px;
        gap: 12px;
    }

        .product-row:last-child {
            border-bottom: none;
        }

    .product-name {
        color: #1a1a1a;
        flex: 1;
    }

    .product-qty {
        color: #888;
        white-space: nowrap;
        margin: 0 12px;
    }

    .product-price {
        font-weight: 600;
        color: #1a1a1a;
        white-space: nowrap;
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0 0;
        margin-top: 8px;
        border-top: 2px solid #f0f0f0;
        font-size: 17px;
        font-weight: 700;
    }

        .total-row .total-label {
            color: #1a1a1a;
        }

        .total-row .total-value {
            color: #e53935;
        }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #fff8e1;
        border: 1px solid #ffe082;
        color: #f57f17;
        font-size: 13px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 6px;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 24px;
    }

    .btn-primary-hdk {
        flex: 1;
        background: #e53935;
        color: #fff;
        border: none;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        text-align: center;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: background 0.2s;
    }

        .btn-primary-hdk:hover {
            background: #c62828;
            color: #fff;
            text-decoration: none;
        }

    .btn-outline-hdk {
        flex: 1;
        background: #fff;
        color: #e53935;
        border: 1.5px solid #e53935;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        text-align: center;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: all 0.2s;
    }

        .btn-outline-hdk:hover {
            background: #fff3f3;
            color: #c62828;
            text-decoration: none;
        }
</style>

<div class="success-wrapper">

    <!-- Header -->
    <div class="success-header">
        <div class="success-icon">
            <i class="bi bi-check-lg"></i>
        </div>
        <h2>Đặt Hàng Thành Công!</h2>
        <p>Cảm ơn bạn đã mua hàng tại <strong>HDKTech</strong>. Đơn hàng của bạn đã được ghi nhận.</p>
        <div class="order-code-badge">
            <i class="bi bi-hash"></i> @Model.OrderCode
        </div>
    </div>

    <!-- Thông tin người nhận -->
    <div class="info-card">
        <h6><i class="bi bi-person"></i> Thông Tin Người Nhận</h6>

        <div class="info-row">
            <span class="label">Họ tên</span>
            <span class="value">@Model.RecipientName</span>
        </div>
        <div class="info-row">
            <span class="label">Số điện thoại</span>
            <span class="value">@Model.RecipientPhone</span>
        </div>
        <div class="info-row">
            <span class="label">Địa chỉ giao hàng</span>
            <span class="value">@Model.ShippingAddress</span>
        </div>
        <div class="info-row">
            <span class="label">Ngày đặt hàng</span>
            <span class="value">@Model.OrderDate.ToString("HH:mm - dd/MM/yyyy")</span>
        </div>
        <div class="info-row">
            <span class="label">Trạng thái</span>
            <span class="value">
                <span class="status-badge">
                    <i class="bi bi-clock"></i> Chờ xác nhận
                </span>
            </span>
        </div>
    </div>

    <!-- Sản phẩm đã đặt -->
    <div class="info-card">
        <h6><i class="bi bi-box"></i> Sản Phẩm Đã Đặt</h6>

        @if (Model.Items != null && Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <div class="product-row">
         
                    <span class="product-qty">× @item.Quantity</span>
                    <span class="product-price">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</span>
                </div>
            }
        }

        <div class="info-row" style="margin-top: 8px;">
            <span class="label" style="color: #555;">Tổng tiền hàng</span>
            <span class="value">@Model.TotalAmount.ToString("N0")₫</span>
        </div>
        <div class="info-row">
            <span class="label" style="color: #555;">Phí vận chuyển</span>
            <span class="value">@(Model.ShippingFee == 0 ? "Miễn phí" : Model.ShippingFee.ToString("N0") + "₫")</span>
        </div>

        <div class="total-row">
            <span class="total-label">Tổng Cộng</span>
            <span class="total-value">@((Model.TotalAmount + Model.ShippingFee).ToString("N0"))₫</span>
        </div>
    </div>

    <!-- Buttons -->
    <div class="action-buttons">
        <a href="/Order/MyOrders" class="btn-outline-hdk">
            <i class="bi bi-list-ul"></i>
            Đơn Hàng Của Tôi
        </a>
        <a href="/" class="btn-primary-hdk">
            <i class="bi bi-house"></i>
            Tiếp Tục Mua Sắm
        </a>
    </div>

</div>
