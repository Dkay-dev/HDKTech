@{
    ViewData["Title"] = "Thanh Toán Thất Bại";
    var canRetry    = (bool)(ViewBag.CanRetry   ?? false);
    var checkoutId  = ViewBag.CheckoutId as Guid?;
}

<style>
    .failed-wrapper {
        max-width: 560px;
        margin: 56px auto;
        padding: 0 16px;
        text-align: center;
    }

    .failed-icon-circle {
        width: 80px;
        height: 80px;
        background: #fdecea;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
    }

        .failed-icon-circle i {
            font-size: 40px;
            color: #e53935;
        }

    .failed-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #212121;
        margin-bottom: 12px;
    }

    .failed-subtitle {
        color: #616161;
        font-size: 0.97rem;
        line-height: 1.6;
        margin-bottom: 36px;
    }

    .failed-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-retry {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #1a73e8;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 12px 28px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-retry:hover {
            background: #1557b0;
            color: #fff;
            text-decoration: none;
        }

    .btn-home {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f5f5f5;
        color: #424242;
        border: none;
        border-radius: 8px;
        padding: 12px 28px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s;
    }

        .btn-home:hover {
            background: #e0e0e0;
            color: #212121;
            text-decoration: none;
        }

    .failed-help {
        margin-top: 32px;
        padding: 16px;
        background: #fff8e1;
        border-left: 4px solid #ffc107;
        border-radius: 6px;
        text-align: left;
        font-size: 0.88rem;
        color: #555;
    }

        .failed-help strong {
            display: block;
            margin-bottom: 4px;
            color: #333;
        }
</style>

<div class="failed-wrapper">

    <div class="failed-icon-circle">
        <i class="bi bi-x-circle-fill"></i>
    </div>

    <h1 class="failed-title">Thanh toán không thành công</h1>

    <p class="failed-subtitle">
        Giao dịch của bạn chưa được xử lý.<br>
        Tiền chưa bị trừ — bạn có thể thử lại hoàn toàn an toàn.
    </p>

    @if (TempData["Error"] is string errMsg)
    {
        <div class="alert alert-danger mb-3" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@errMsg
        </div>
    }

    <div class="failed-actions">
        @if (canRetry && checkoutId.HasValue)
        {
            <a href="@Url.Action("Index", "Checkout")" class="btn-retry">
                <i class="bi bi-arrow-repeat"></i> Thử lại
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Checkout")" class="btn-retry">
                <i class="bi bi-cart3"></i> Quay lại thanh toán
            </a>
        }

        <a href="@Url.Action("Index", "Home")" class="btn-home">
            <i class="bi bi-house"></i> Về trang chủ
        </a>
    </div>

    <div class="failed-help">
        <strong>Cần hỗ trợ?</strong>
        Nếu tiền đã bị trừ nhưng đơn hàng chưa được tạo, vui lòng liên hệ chúng tôi
        qua hotline hoặc email để được hoàn tiền nhanh nhất.
        @if (checkoutId.HasValue)
        {
            <br />
            <span class="text-muted">Mã phiên: <code>@checkoutId.Value.ToString()[..8].ToUpper()…</code></span>
        }
    </div>

</div>
