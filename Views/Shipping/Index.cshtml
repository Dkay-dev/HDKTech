@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh Toán";
}

<link rel="stylesheet" href="~/css/pages/checkout.css" />
<script src="https://esgoo.net/scripts/jquery.js"></script>

<style>
    /* ── Shipping location selector ── */
    .shipping-location-card {
        background: #f8f9ff;
        border: 1px solid #dde3f5;
        border-radius: 10px;
        padding: 16px 18px;
        margin-top: 8px;
    }

    .location-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .location-row select {
            flex: 1;
            min-width: 140px;
            padding: 9px 12px;
            border: 1.5px solid #ccd4ee;
            border-radius: 8px;
            font-size: 0.9rem;
            background: #fff;
            color: #333;
            transition: border-color .2s;
            cursor: pointer;
        }

            .location-row select:focus {
                outline: none;
                border-color: #4f6ef7;
                box-shadow: 0 0 0 3px rgba(79,110,247,.12);
            }

            .location-row select:disabled {
                background: #f0f0f0;
                color: #aaa;
                cursor: not-allowed;
            }

    /* ── Shipping fee badge ── */
    #shipping-fee-result {
        display: none;
        margin-top: 12px;
        padding: 12px 16px;
        border-radius: 9px;
        font-size: 0.9rem;
        animation: fadeIn .3s ease;
    }

        #shipping-fee-result.zone-a {
            background: #e8f8f0;
            border: 1px solid #b2dfcc;
            color: #1a7a45;
        }

        #shipping-fee-result.zone-b {
            background: #eef4ff;
            border: 1px solid #bdd0f7;
            color: #2a4fbf;
        }

        #shipping-fee-result.zone-c,
        #shipping-fee-result.zone-d {
            background: #fff5e6;
            border: 1px solid #f6d198;
            color: #8a5500;
        }

        #shipping-fee-result .fee-icon {
            margin-right: 6px;
        }

        #shipping-fee-result .fee-amount {
            font-weight: 700;
            font-size: 1.05rem;
        }

    /* ── Summary panel live update ── */
    #summary-shipping-fee {
        transition: color .3s;
    }

    #summary-total-amount {
        transition: color .3s;
    }

    /* ── Loading spinner inside select ── */
    .select-loading {
        opacity: .6;
        pointer-events: none;
    }

  {
        from {
            opacity: 0;
            transform: translateY(-4px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container">
    <div class="checkout-container">
        <div class="checkout-title">
            <i class="bi bi-credit-card"></i>
            Xác Nhận Thanh Toán
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="error-message">
                <i class="bi bi-exclamation-circle"></i>
                @TempData["Error"]
            </div>
        }

        <form method="post" action="/Checkout" id="checkoutForm" novalidate>
            @Html.AntiForgeryToken()

            <input type="hidden" name="TotalAmount" id="hiddenTotal" value="@Model.TotalAmount" />
            <input type="hidden" name="ShippingFee" id="hiddenShipping" value="@Model.ShippingFee" />
            <input type="hidden" name="SoProduct" value="@Model.SoProduct" />
            <input type="hidden" name="CityName" id="hiddenCityName" value="" />
            <input type="hidden" name="DistrictName" id="hiddenDistrictName" value="" />
            <input type="hidden" name="WardName" id="hiddenWardName" value="" />

            <div class="row">
                <!-- ══ Left: Form ══ -->
                <div class="col-lg-7">
                    <div class="form-section">
                        <h5>
                            <i class="bi bi-person-check"></i>
                            Thông Tin Người Nhận
                        </h5>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-person"></i> Họ Tên
                            </label>
                            <input type="text"
                                   class="form-control @(ViewData.ModelState["RecipientName"]?.Errors.Any() == true ? "is-invalid" : "")"
                                   name="RecipientName" value="@Model.RecipientName" placeholder="Nhập họ tên">
                            @if (ViewData.ModelState["RecipientName"]?.Errors.Any() == true)
                            {
                                <span class="invalid-feedback">@ViewData.ModelState["RecipientName"].Errors[0].ErrorMessage</span>
                            }
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-envelope"></i> Email
                            </label>
                            <input type="email"
                                   class="form-control @(ViewData.ModelState["Email"]?.Errors.Any() == true ? "is-invalid" : "")"
                                   name="Email" value="@Model.Email" placeholder="Nhập email">
                            @if (ViewData.ModelState["Email"]?.Errors.Any() == true)
                            {
                                <span class="invalid-feedback">@ViewData.ModelState["Email"].Errors[0].ErrorMessage</span>
                            }
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-telephone"></i> Số Điện Thoại
                            </label>
                            <input type="tel"
                                   class="form-control @(ViewData.ModelState["SoDienThoai"]?.Errors.Any() == true ? "is-invalid" : "")"
                                   name="SoDienThoai" value="@Model.SoDienThoai" placeholder="Nhập số điện thoại">
                            @if (ViewData.ModelState["SoDienThoai"]?.Errors.Any() == true)
                            {
                                <span class="invalid-feedback">@ViewData.ModelState["SoDienThoai"].Errors[0].ErrorMessage</span>
                            }
                        </div>

                        <!-- ══ Shipping Address + Location Picker ══ -->
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-geo-alt"></i> Địa Chỉ Giao Hàng
                            </label>
                            <input type="text"
                                   class="form-control @(ViewData.ModelState["ShippingAddress"]?.Errors.Any() == true ? "is-invalid" : "")"
                                   name="ShippingAddress" id="shippingAddress"
                                   value="@Model.ShippingAddress"
                                   placeholder="Số nhà, tên đường...">
                            @if (ViewData.ModelState["ShippingAddress"]?.Errors.Any() == true)
                            {
                                <span class="invalid-feedback">@ViewData.ModelState["ShippingAddress"].Errors[0].ErrorMessage</span>
                            }

                            <!-- Dropdown chọn Tỉnh / Quận / Phường -->
                            <div class="shipping-location-card mt-2">
                                <div class="location-row">
                                    <select id="tinh" name="tinh" title="Chọn Tỉnh Thành">
                                        <option value="0">🏙️ Tỉnh / Thành phố</option>
                                    </select>
                                    <select id="quan" name="quan" title="Chọn Quận Huyện" disabled>
                                        <option value="0">🏘️ Quận / Huyện</option>
                                    </select>
                                    <select id="phuong" name="phuong" title="Chọn Phường Xã" disabled>
                                        <option value="0">📍 Phường / Xã</option>
                                    </select>
                                </div>

                                <!-- Kết quả phí ship -->
                                <div id="shipping-fee-result">
                                    <span class="fee-icon">🚚</span>
                                    <span id="fee-label">Phí vận chuyển:</span>
                                    <span class="fee-amount" id="fee-value"></span>
                                    <span id="fee-note" style="margin-left:6px; font-size:.82rem; opacity:.75;"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-chat-left-text"></i> Ghi Chú
                            </label>
                            <textarea class="form-control" name="GhiChu" rows="3"
                                      placeholder="Nhập ghi chú (tùy chọn)">@Model.GhiChu</textarea>
                        </div>
                    </div>

                    <!-- ══ Phương Thức Thanh Toán ══ -->
                    <div class="form-section">
                        <h5>
                            <i class="bi bi-wallet2"></i>
                            Phương Thức Thanh Toán
                        </h5>

                        <div class="payment-method active" id="pm-cod">
                            <input type="radio" id="cod" name="PaymentMethod" value="COD" checked>
                            <label for="cod" style="margin:0;cursor:pointer;flex:1;">
                                <i class="bi bi-truck"></i>
                                <strong>Thanh Toán Khi Nhận Hàng (COD)</strong><br>
                                <small style="color:#666;">Không phí, giao hàng nhanh</small>
                            </label>
                        </div>

                        <div class="payment-method" id="pm-vnpay">
                            <input type="radio" id="vnpay" name="PaymentMethod" value="VNPAY">
                            <label for="vnpay" style="margin:0;cursor:pointer;flex:1;">
                                <img src="~/images/payment/vnpay-logo.png" alt="VNPay" height="22"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='inline';" />
                                <i class="bi bi-credit-card-2-front" style="display:none;"></i>
                                <strong>Thanh Toán Qua VNPay</strong><br>
                                <small style="color:#666;">ATM, Visa, Mastercard, QR Code</small>
                            </label>
                        </div>

                        <div class="payment-method" id="pm-momo">
                            <input type="radio" id="momo" name="PaymentMethod" value="Momo">
                            <label for="momo" style="margin:0;cursor:pointer;flex:1;">
                                <img src="~/images/payment/momo-logo.png" alt="MoMo" height="22"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='inline';" />
                                <i class="bi bi-wallet2" style="display:none;"></i>
                                <strong>Thanh Toán Qua MoMo</strong><br>
                                <small style="color:#666;">Ví MoMo, QR Code</small>
                            </label>
                        </div>

                        <div class="payment-method" id="pm-bank">
                            <input type="radio" id="bank" name="PaymentMethod" value="BANK" disabled>
                            <label for="bank" style="margin:0;cursor:not-allowed;flex:1;color:#999;">
                                <i class="bi bi-bank"></i>
                                <strong>Chuyển Khoản Ngân Hàng</strong><br>
                                <small>(Đang phát triển)</small>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- ══ Right: Order Summary ══ -->
                <div class="col-lg-5">
                    <div class="order-summary">
                        <h5>
                            <i class="bi bi-receipt"></i>
                            Tóm Tắt Đơn Hàng
                        </h5>

                        @if (Model.Items != null && Model.Items.Any())
                        {
                            @foreach (var item in Model.Items)
                            {
                                <div class="summary-item">
                                    <div class="summary-item-name">@item.ProductName</div>
                                    <div class="summary-item-qty">×@item.Quantity</div>
                                    <div class="summary-item-price">@((item.Price * item.Quantity).ToString("N0"))₫</div>
                                </div>
                            }
                        }

                        <div class="summary-divider"></div>

                        <div class="summary-item">
                            <span>Tổng Tiền Hàng:</span>
                            <span style="font-weight:600;color:var(--hdk-dark);">@Model.TotalAmount.ToString("N0")₫</span>
                        </div>

                        <div class="summary-item">
                            <span>Phí Vận Chuyển:</span>
                            <span id="summary-shipping-fee" style="font-weight:600;color:var(--hdk-dark);">
                                @(Model.ShippingFee == 0 ? "Chưa chọn địa chỉ" : (Model.ShippingFee.ToString("N0") + "₫"))
                            </span>
                        </div>

                        <div class="summary-total">
                            <span>Tổng Cộng:</span>
                            <span id="summary-total-amount">@((Model.TotalAmount + Model.ShippingFee).ToString("N0"))₫</span>
                        </div>

                        <button type="submit" id="btnSubmit" class="btn-checkout">
                            <i class="bi bi-check-circle" id="btnIcon"></i>
                            <span id="btnText">XÁC NHẬN ĐẶT HÀNG</span>
                        </button>

                        <a href="/Cart" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="bi bi-arrow-left"></i>
                            Quay Lại Giỏ Hàng
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    $(document).ready(function () {

        var baseTotal = @Model.TotalAmount;   // Tổng tiền hàng (không đổi)
        var currentFee = @Model.ShippingFee;  // Phí ship hiện tại

        // ── Helpers ────────────────────────────────────────────────────────────
        function formatVND(amount) {
            return amount.toLocaleString('vi-VN') + '₫';
        }

        function updateSummaryPanel(fee, feeFormatted) {
            currentFee = fee;
            $('#hiddenShipping').val(fee);
            $('#summary-shipping-fee').text(feeFormatted === 'Miễn phí' ? '🎉 Miễn phí' : feeFormatted);
            $('#summary-total-amount').text(formatVND(baseTotal + fee));
        }

        function showFeeResult(fee, feeFormatted, zone, cityName) {
            var el = $('#shipping-fee-result');
            el.removeClass('zone-a zone-b zone-c zone-d').addClass('zone-' + zone.toLowerCase());

            var noteMap = {
                'A': '(Giao hàng nội thành Đà Nẵng)',
                'B': '(Miền Trung)',
                'C': '(Miền Nam)',
                'D': '(Miền Bắc)'
            };

            $('#fee-value').text(feeFormatted === 'Miễn phí' ? '🎉 Miễn phí' : feeFormatted);
            $('#fee-note').text(noteMap[zone] || '');
            el.fadeIn(250);
        }

        function autoFillAddress() {
            var parts = [];
            var ward     = $('#phuong option:selected').text();
            var district = $('#quan option:selected').text();
            var city     = $('#tinh option:selected').text();

            if (ward     && ward     !== '📍 Phường / Xã')      parts.push(ward);
            if (district && district !== '🏘️ Quận / Huyện')    parts.push(district);
            if (city     && city     !== '🏙️ Tỉnh / Thành phố') parts.push(city);

            if (parts.length > 0) {
                var current = $('#shippingAddress').val().trim();
                // Chỉ điền nếu ô trống hoặc đang là địa chỉ tự động trước đó
                if (!current || $('#shippingAddress').data('auto') === true) {
                    $('#shippingAddress').val(parts.join(', '));
                    $('#shippingAddress').data('auto', true);
                }
            }
        }

        // ── Gọi API tính phí ship ───────────────────────────────────────────
        function fetchShippingFee(cityId, cityName, districtId, districtName, wardId, wardName) {
            if (!cityName || cityName === '🏙️ Tỉnh / Thành phố') return;

            $.ajax({
                url: '/Shipping/CalculateFee',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    CityId: cityId,
                    CityName: cityName,
                    DistrictId: districtId || '',
                    DistrictName: districtName || '',
                    WardId: wardId || '',
                    WardName: wardName || ''
                }),
                success: function (res) {
                    if (res.success) {
                        updateSummaryPanel(res.fee, res.feeFormatted);
                        showFeeResult(res.fee, res.feeFormatted, res.zone, cityName);

                        // Lưu tên địa chỉ vào hidden inputs
                        $('#hiddenCityName').val(cityName);
                        $('#hiddenDistrictName').val(districtName || '');
                        $('#hiddenWardName').val(wardName || '');
                    }
                }
            });
        }

        // ── Esgoo: Tải Tỉnh Thành ──────────────────────────────────────────
        $.getJSON('https://esgoo.net/api-tinhthanh/1/0.htm', function (data) {
            if (data.error === 0) {
                $.each(data.data, function (k, v) {
                    $('#tinh').append('<option value="' + v.id + '" data-name="' + v.full_name + '">' + v.full_name + '</option>');
                });
            }
        });

        // ── Khi chọn Tỉnh Thành ────────────────────────────────────────────
        $('#tinh').on('change', function () {
            var idTinh   = $(this).val();
            var nameTinh = $('option:selected', this).data('name') || $('option:selected', this).text();

            // Reset cấp dưới
            $('#quan').html('<option value="0">🏘️ Quận / Huyện</option>').prop('disabled', true);
            $('#phuong').html('<option value="0">📍 Phường / Xã</option>').prop('disabled', true);
            $('#shipping-fee-result').fadeOut(150);

            if (idTinh === '0') {
                updateSummaryPanel(0, '—');
                $('#summary-shipping-fee').text('Chưa chọn địa chỉ');
                $('#summary-total-amount').text(formatVND(baseTotal));
                return;
            }

            // Tính phí ngay khi chọn tỉnh
            fetchShippingFee(idTinh, nameTinh, '', '', '', '');
            autoFillAddress();

            // Tải Quận/Huyện
            $.getJSON('https://esgoo.net/api-tinhthanh/2/' + idTinh + '.htm', function (data) {
                if (data.error === 0) {
                    $.each(data.data, function (k, v) {
                        $('#quan').append('<option value="' + v.id + '" data-name="' + v.full_name + '">' + v.full_name + '</option>');
                    });
                    $('#quan').prop('disabled', false);
                }
            });
        });

        // ── Khi chọn Quận/Huyện ────────────────────────────────────────────
        $('#quan').on('change', function () {
            var idQuan   = $(this).val();
            var nameQuan = $('option:selected', this).data('name') || $('option:selected', this).text();
            var nameTinh = $('option:selected', $('#tinh')).data('name') || $('option:selected', $('#tinh')).text();
            var idTinh   = $('#tinh').val();

            $('#phuong').html('<option value="0">📍 Phường / Xã</option>').prop('disabled', true);

            if (idQuan === '0') return;

            // Cập nhật phí (phí không đổi theo quận, chỉ theo tỉnh — nhưng giữ UX nhất quán)
            fetchShippingFee(idTinh, nameTinh, idQuan, nameQuan, '', '');
            autoFillAddress();

            // Tải Phường/Xã
            $.getJSON('https://esgoo.net/api-tinhthanh/3/' + idQuan + '.htm', function (data) {
                if (data.error === 0) {
                    $.each(data.data, function (k, v) {
                        $('#phuong').append('<option value="' + v.id + '" data-name="' + v.full_name + '">' + v.full_name + '</option>');
                    });
                    $('#phuong').prop('disabled', false);
                }
            });
        });

        // ── Khi chọn Phường/Xã ─────────────────────────────────────────────
        $('#phuong').on('change', function () {
            if ($(this).val() === '0') return;

            var namePhuong = $('option:selected', this).data('name') || $('option:selected', this).text();
            var nameQuan   = $('option:selected', $('#quan')).data('name')  || $('option:selected', $('#quan')).text();
            var nameTinh   = $('option:selected', $('#tinh')).data('name')  || $('option:selected', $('#tinh')).text();
            var idTinh     = $('#tinh').val();
            var idQuan     = $('#quan').val();

            fetchShippingFee(idTinh, nameTinh, idQuan, nameQuan, $(this).val(), namePhuong);
            autoFillAddress();
            $('#hiddenWardName').val(namePhuong);
        });

        // Nếu user tự gõ địa chỉ thì không auto-fill nữa
        $('#shippingAddress').on('input', function () {
            $(this).data('auto', false);
        });

        // ── Payment method UI ───────────────────────────────────────────────
        $('input[name="PaymentMethod"]').on('change', function () {
            var btn  = $('#btnSubmit');
            var icon = $('#btnIcon');
            var text = $('#btnText');

            $('.payment-method').removeClass('active');
            $(this).closest('.payment-method').addClass('active');

            if (this.value === 'VNPAY') {
                btn.css('background', '#005BAA');
                icon.attr('class', 'bi bi-credit-card-2-front');
                text.text('THANH TOÁN QUA VNPAY');
            } else if (this.value === 'Momo') {
                btn.css('background', '#A72930');
                icon.attr('class', 'bi bi-wallet2');
                text.text('THANH TOÁN QUA MOMO');
            } else {
                btn.css('background', '');
                icon.attr('class', 'bi bi-check-circle');
                text.text('XÁC NHẬN ĐẶT HÀNG');
            }
        });

        // ── Loading state khi submit ────────────────────────────────────────
        $('#checkoutForm').on('submit', function () {
            $('#btnSubmit').prop('disabled', true);
            $('#btnIcon').attr('class', 'bi bi-hourglass-split');
            $('#btnText').text('ĐANG XỬ LÝ...');
        });

    });
</script>
