@{
    ViewData["Title"] = "Trung Tâm Hỗ Trợ Hotline";
}

<div class="container py-5">
    @* --- Header Hotline --- *@
    <div class="text-center mb-5">
        <div class="bg-danger d-inline-block p-3 rounded-circle mb-3 shadow">
            <i class="bi bi-headphones fs-1 text-white"></i>
        </div>
        <h1 class="fw-bold">TỔNG ĐÀI HỖ TRỢ <span class="text-danger">HDKTECH</span></h1>
        <p class="text-muted">Chúng tôi luôn sẵn sàng lắng nghe và giải đáp mọi thắc mắc của bạn 24/7</p>
    </div>

    <div class="row g-4">
        @* --- Cột 1: Hotline Bán Hàng --- *@
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4 transition-card">
                <h5 class="fw-bold mb-3 text-uppercase">Tư vấn bán hàng</h5>
                <p class="text-muted small">Liên hệ để được tư vấn cấu hình PC và linh kiện phù hợp nhất.</p>
                <a href="tel:19008899" class="h3 fw-bold text-danger text-decoration-none">1900.8899</a>
                <p class="mt-2 mb-0 fw-bold"><i class="bi bi-clock me-1"></i> 08:00 - 21:00</p>
            </div>
        </div>

        @* --- Cột 2: Hotline Kỹ thuật (Trọng tâm của Tech Shop) --- *@
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow bg-dark text-white text-center p-4 scale-up">
                <h5 class="fw-bold mb-3 text-uppercase text-danger">Hỗ trợ kỹ thuật</h5>
                <p class="text-light opacity-75 small">Gặp sự cố về phần cứng hoặc phần mềm? Hãy gọi ngay đội ngũ kỹ sư của chúng tôi.</p>
                <a href="tel:19008800" class="h3 fw-bold text-white text-decoration-none">1900.8800</a>
                <p class="mt-2 mb-0 fw-bold"><i class="bi bi-shield-fill-check text-danger me-1"></i> Hỗ trợ 24/7</p>
            </div>
        </div>

        @* --- Cột 3: Khiếu nại & Góp ý --- *@
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4 transition-card">
                <h5 class="fw-bold mb-3 text-uppercase">Góp ý & Khiếu nại</h5>
                <p class="text-muted small">Dịch vụ chưa tốt? Hãy để chúng tôi lắng nghe để hoàn thiện hơn.</p>
                <a href="tel:19001122" class="h3 fw-bold text-secondary text-decoration-none">1900.1122</a>
                <p class="mt-2 mb-0 fw-bold"><i class="bi bi-envelope-at me-1"></i> cskh@hdktech.vn</p>
            </div>
        </div>
    </div>

    @* --- Phần Kênh Liên Lạc Khác --- *@
    <div class="mt-5 p-5 bg-light rounded-4 border">
        <div class="row align-items-center text-center text-md-start">
            <div class="col-md-8">
                <h4 class="fw-bold"><i class="bi bi-chat-dots-fill text-danger me-2"></i>Bạn muốn nhắn tin trực tiếp?</h4>
                <p class="mb-0 text-muted">Kết nối với chúng tôi qua Facebook Messenger hoặc Zalo để được phản hồi trong vòng 5 phút.</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a href="#" class="btn btn-primary btn-lg rounded-pill px-4 me-2"><i class="bi bi-facebook"></i> Messenger</a>
                <a href="#" class="btn btn-info btn-lg rounded-pill px-4 text-white"><i class="bi bi-chat-fill"></i> Zalo OA</a>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-card {
        transition: all 0.3s ease;
        border-bottom: 3px solid transparent !important;
    }

        .transition-card:hover {
            transform: translateY(-5px);
            border-bottom: 3px solid #dc3545 !important;
        }

    .scale-up {
        transform: scale(1.05);
        z-index: 1;
    }
</style>