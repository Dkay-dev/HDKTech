@model HDKTech.Models.HomeIndexViewModel
@using HDKTech.Utils
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    ViewData["Title"] = "Trang Chủ - HDKTech - Cửa Hàng Máy Tính Hàng Đầu";
}

<link rel="stylesheet" href="~/css/pages/home.css" />

<!-- ============================================
     1. HERO BANNER CAROUSEL (Admin-Managed)
     ============================================ -->
@if (Model.MainBanners.Any())
{
    <div class="container-fluid p-0 mb-0">
        <div id="mainBannerCarousel" class="carousel slide carousel-fade main-banner-carousel" data-bs-ride="carousel" data-bs-interval="5000">
            <div class="carousel-inner">
                @foreach (var banner in Model.MainBanners)
                {
                    bool hasLink = !string.IsNullOrWhiteSpace(banner.LinkUrl);
                    bool isExternal = hasLink && (banner.LinkUrl.StartsWith("http://") || banner.LinkUrl.StartsWith("https://"));
                    string target = isExternal ? "_blank" : "_self";

                    <div class="carousel-item @(Model.MainBanners.IndexOf(banner) == 0 ? "active" : "")">

                        @* Nếu có link → bọc <a> để cả banner thành nút bấm; không có → chỉ hiện ảnh *@
                        @if (hasLink)
                        {
                            <a href="@banner.LinkUrl"
                                   target="@target"
                                   rel="@(isExternal ? "noopener noreferrer" : null)"
                                   class="banner-link d-block"
                                   onclick="trackBannerClick(@banner.Id); return true;">
                                <img src="@banner.ImageUrl" alt="@banner.Title" class="d-block w-100"
                                     style="height: 75vh; min-height: 500px; object-fit: cover;"
                                     loading="@(Model.MainBanners.IndexOf(banner) == 0 ? "eager" : "lazy")" />
                            </a>
                        }
                        else
                        {
                            <img src="@banner.ImageUrl" alt="@banner.Title" class="d-block w-100"
                                 style="height: 75vh; min-height: 500px; object-fit: cover;"
                                 loading="@(Model.MainBanners.IndexOf(banner) == 0 ? "eager" : "lazy")" />
                        }

                        <div class="carousel-caption d-md-block" style="bottom: 20%; background: rgba(0,0,0,0.2); backdrop-filter: blur(5px); border-radius: 15px; padding: 20px;">
                            <h2 class="fw-bold display-4" style="text-shadow: 2px 2px 10px rgba(0,0,0,0.8);">@banner.Title</h2>
                            @if (!string.IsNullOrEmpty(banner.Description))
                            {
                                <p class="lead fs-4" style="text-shadow: 1px 1px 5px rgba(0,0,0,0.6);">@banner.Description</p>
                            }
                        </div>

                    </div>
                }
            </div>

            @if (Model.MainBanners.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#mainBannerCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#mainBannerCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

                <div class="carousel-indicators">
                    @foreach (var banner in Model.MainBanners)
                    {
                        <button type="button" data-bs-target="#mainBannerCarousel" data-bs-slide-to="@Model.MainBanners.IndexOf(banner)"
                                class="@(Model.MainBanners.IndexOf(banner) == 0 ? "active" : "")"
                                aria-current="@(Model.MainBanners.IndexOf(banner) == 0 ? "true" : "false")"></button>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info text-center py-5 m-0">
        <p class="mb-0">Chưa có banner nào. <a href="/Admin/Banner">Tạo banner ngay</a></p>
    </div>
}


<!-- ============================================
     3. FEATURED CATEGORIES
     ============================================ -->
<section class="featured-categories py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold section-title-main">Danh Mục</h2>
            <div class="title-underline mx-auto"></div>
        </div>

        @if (Model.Categories.Any())
        {
            <div class="row g-4 justify-content-center">
                @foreach (var category in Model.Categories.Where(m => m.ParentCategoryId == null).Take(14))
                {
                    <div class="col-4 col-md-3 col-lg-2">
                        <a asp-controller="Category" asp-action="Index" asp-route-id="@category.Id"
                               class="text-decoration-none category-item-modern">
                            <div class="category-icon-wrapper shadow-sm mb-3">
                                <img src="/images/banners/category-@(category.Id).jpg"
                                     alt="@category.Name"
                                     onerror="this.src='/images/banners/category-1.jpg'"
                                     class="img-fluid p-3 category-img-render">
                            </div>
                            <h6 class="category-name-modern text-center">@category.Name</h6>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</section>

<!-- ============================================
     4. FEATURED PRODUCTS & NEW ARRIVALS
     ============================================ -->
<section class="product-sections py-5">
    <div class="container">
        <!-- TOP SELLER PRODUCTS -->
        @if (Model.TopSellerProducts.Any())
        {
            <div class="product-section mb-5">
                <div class="section-header">
                    <div class="section-title"><i class="bi bi-lightning"></i> LAPTOP BÁN CHẠY</div>
                    <a asp-controller="Product" asp-action="Index" asp-route-sortOrder="popular" class="view-all-btn">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="products-grid">
                    @foreach (var product in Model.TopSellerProducts.Take(8))
                    {
                        <div class="product-card-wrapper">
                            <div class="product-card">
                                <div class="product-image-container">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="product-image-link">
                                        @{
                                            var imgUrl = Url.Content("/images/products/" + (product.Images?.FirstOrDefault(h => h.IsDefault)?.ImageUrl ?? product.Images?.FirstOrDefault()?.ImageUrl ?? "no-image.png"));
                                        }
                                        <img src="@imgUrl" alt="@product.Name" class="product-image" onerror="this.src='/images/products/no-image.png'" />
                                    </a>

                                    @if (product.DiscountPercent > 0)
                                    {
                                        <span class="product-badge-discount">-@product.DiscountPercent%</span>
                                    }
                                    <span class="product-badge-new">MỚI</span>

                                    <button type="button" class="product-add-btn" onclick="addToCartAjax(@product.Id, '@product.Name')">
                                        <i class="bi bi-cart-plus"></i> Thêm Giỏ
                                    </button>
                                </div>

                                <div class="product-info">
                                    <h5 class="product-name">
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id">
                                            @product.Name
                                        </a>
                                    </h5>

                                    <div class="product-rating">
                                        <div class="rating-stars">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                        </div>
                                        <span class="rating-count">Đã bán 234</span>
                                    </div>

                                    <div class="product-price-group">
                                        @if (product.ListPrice.HasValue && product.ListPrice > product.Price)
                                        {
                                            <span class="product-price-old">@product.ListPrice.Value.ToString("#,##0")₫</span>
                                        }
                                        <span class="product-price-current">@product.Price.ToString("#,##0")₫</span>
                                    </div>

                                    <button type="button" class="btn-installment">
                                        <i class="bi bi-percent"></i> Trả góp 0%
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- NEW ARRIVALS -->
        @if (Model.NewProducts.Any())
        {
            <div class="product-section">
                <div class="section-header">
                    <div class="section-title"><i class="bi bi-star-fill"></i> LINH KIỆN MỚI VỀ</div>
                    <a asp-controller="Product" asp-action="Index" asp-route-sortOrder="newest" class="view-all-btn">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="products-grid">
                    @foreach (var product in Model.NewProducts.Take(8))
                    {
                        <div class="product-card-wrapper">
                            <div class="product-card">
                                <div class="product-image-container">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="product-image-link">
                                        @{
                                            var imgUrl = Url.Content("/images/products/" + (product.Images?.FirstOrDefault(h => h.IsDefault)?.ImageUrl ?? product.Images?.FirstOrDefault()?.ImageUrl ?? "no-image.png"));
                                        }
                                        <img src="@imgUrl" alt="@product.Name" class="product-image" onerror="this.src='/images/products/no-image.png'" />
                                    </a>

                                    @if (product.DiscountPercent > 0)
                                    {
                                        <span class="product-badge-discount">-@product.DiscountPercent%</span>
                                    }
                                    <span class="product-badge-new">MỚI</span>

                                    <button type="button" class="product-add-btn" onclick="addToCartAjax(@product.Id, '@product.Name')">
                                        <i class="bi bi-cart-plus"></i> Thêm Giỏ
                                    </button>
                                </div>

                                <div class="product-info">
                                    <h5 class="product-name">
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id">
                                            @product.Name
                                        </a>
                                    </h5>

                                    <div class="product-rating">
                                        <div class="rating-stars">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                        </div>
                                        <span class="rating-count">Đã bán 234</span>
                                    </div>

                                    <div class="product-price-group">
                                        @if (product.ListPrice.HasValue && product.ListPrice > product.Price)
                                        {
                                            <span class="product-price-old">@product.ListPrice.Value.ToString("#,##0")₫</span>
                                        }
                                        <span class="product-price-current">@product.Price.ToString("#,##0")₫</span>
                                    </div>

                                    <button type="button" class="btn-installment">
                                        <i class="bi bi-percent"></i> Trả góp 0%
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/pages/home.js"></script>
    <script>
        function trackBannerClick(bannerId) {
            if (!bannerId) return;
            fetch(`/api/banneranalytics/track-click/${bannerId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            }).catch(() => {});
        }
    </script>
}

@functions {
    string GetCategoryIcon(int categoryId)
    {
        return categoryId switch
        {
            1 => "bi-laptop",
            2 => "bi-pc-display",
            3 => "bi-keyboard",
            4 => "bi-mouse3",
            5 => "bi-cpu",
            6 => "bi-memory",
            7 => "bi-hdd",
            8 => "bi-display",
            _ => "bi-box2-heart"
        };
    }
}
