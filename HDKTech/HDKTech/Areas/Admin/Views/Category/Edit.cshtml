@model HDKTech.Models.Category

@{
    ViewData["Title"] = $"Chỉnh sửa: {Model?.Name}";
    var parentCategories = ViewBag.ParentCategories as List<HDKTech.Models.Category>
                           ?? new List<HDKTech.Models.Category>();
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
}

<div class="p-3">

    <!-- ── Breadcrumb ──────────────────────────────────────────────── -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Category", new { area = "Admin" })" class="text-decoration-none">
                    <i class="fa-solid fa-tags me-1"></i>Danh mục
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Details", "Category", new { area = "Admin", id = Model?.Id })"
                   class="text-decoration-none">@Model?.Name</a>
            </li>
            <li class="breadcrumb-item active">Chỉnh sửa</li>
        </ol>
    </nav>

    <h5 class="fw-bold mb-4">
        <i class="fa-solid fa-pen-to-square text-primary me-2"></i>
        Chỉnh sửa Danh Mục
    </h5>

    <form asp-action="Edit" asp-controller="Category" asp-area="Admin"
          method="post" asp-route-id="@Model?.Id">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">

            <!-- ── Cột trái: Form nhập liệu ──────────────────────── -->
            <div class="col-lg-8">

                <!-- Card: Thông tin cơ bản -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="fa-solid fa-circle-info text-primary me-2"></i>Thông tin danh mục
                    </div>
                    <div class="card-body">

                        <!-- Tên danh mục -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">
                                Tên danh mục <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="fa-solid fa-tag text-muted fa-sm"></i>
                                </span>
                                <input asp-for="Name"
                                       class="form-control"
                                       placeholder="Tên danh mục..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <!-- Mô tả -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Mô tả chi tiết..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- Banner URL -->
                        <div class="mb-0">
                            <label asp-for="BannerImageUrl" class="form-label fw-semibold">
                                URL hình ảnh banner
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="fa-solid fa-image text-muted fa-sm"></i>
                                </span>
                                <input asp-for="BannerImageUrl"
                                       type="url"
                                       class="form-control"
                                       placeholder="https://..."
                                       id="bannerUrlInput" />
                            </div>
                            <span asp-validation-for="BannerImageUrl" class="text-danger small"></span>
                            @if (!string.IsNullOrEmpty(Model?.BannerImageUrl))
                            {
                                <div id="bannerPreview" class="mt-2">
                                    <img id="previewImg" src="@Model.BannerImageUrl" alt="Banner preview"
                                         class="img-fluid rounded border"
                                         style="max-height:160px; object-fit:cover;" />
                                </div>
                            }
                            else
                            {
                                <div id="bannerPreview" class="mt-2 d-none">
                                    <img id="previewImg" src="" alt="Preview"
                                         class="img-fluid rounded border"
                                         style="max-height:160px; object-fit:cover;" />
                                </div>
                            }
                        </div>

                    </div>
                </div>

                <!-- Card: Phân cấp -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="fa-solid fa-sitemap text-warning me-2"></i>Phân cấp danh mục
                    </div>
                    <div class="card-body">
                        <label asp-for="ParentCategoryId" class="form-label fw-semibold">
                            Danh mục cha
                        </label>
                        <select asp-for="ParentCategoryId" class="form-select">
                            <option value="">-- Không chọn (Đây là danh mục gốc) --</option>
                            @foreach (var parent in parentCategories)
                            {
                                <option value="@parent.Id"
                                        selected="@(Model?.ParentCategoryId == parent.Id)">
                                    @parent.Name
                                </option>
                            }
                        </select>
                        <span asp-validation-for="ParentCategoryId" class="text-danger small"></span>
                        <div class="form-text">
                            <i class="fa-solid fa-triangle-exclamation text-warning me-1"></i>
                            Không thể chọn chính danh mục này làm cha.
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── Cột phải: Actions + Thông tin ────────────────── -->
            <div class="col-lg-4">

                <!-- Card: Hành động -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-floppy-disk me-2"></i>Lưu thay đổi
                            </button>
                            <a href="@Url.Action("Details", "Category", new { area = "Admin", id = Model?.Id })"
                               class="btn btn-outline-secondary">
                                <i class="fa-solid fa-eye me-2"></i>Xem chi tiết
                            </a>
                            <a href="@Url.Action("Index", "Category", new { area = "Admin" })"
                               class="btn btn-outline-secondary">
                                <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Card: Thông tin meta -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-semibold border-bottom">
                        <i class="fa-solid fa-circle-info text-secondary me-2"></i>Thông tin
                    </div>
                    <div class="card-body">
                        <dl class="row small mb-0">
                            <dt class="col-5 text-muted">Mã</dt>
                            <dd class="col-7 fw-semibold">#@Model?.Id</dd>

                            <dt class="col-5 text-muted">Trạng thái</dt>
                            <dd class="col-7">
                                <span class="badge bg-success bg-opacity-75">Hoạt động</span>
                            </dd>

                            @if (Model?.ParentCategory != null)
                            {
                                <dt class="col-5 text-muted">Danh mục cha</dt>
                                <dd class="col-7">@Model.ParentCategory.Name</dd>
                            }

                            <dt class="col-5 text-muted">Sản phẩm</dt>
                            <dd class="col-7">@(Model?.Products?.Count ?? 0)</dd>

                            <dt class="col-5 text-muted">DM con</dt>
                            <dd class="col-7 mb-0">@(Model?.SubCategories?.Count ?? 0)</dd>
                        </dl>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // Preview banner khi thay đổi URL
        const bannerInput = document.getElementById('bannerUrlInput');
        const previewImg  = document.getElementById('previewImg');
        const preview     = document.getElementById('bannerPreview');

        bannerInput?.addEventListener('input', function () {
            const val = this.value.trim();
            if (val) {
                previewImg.src = val;
                preview?.classList.remove('d-none');
                previewImg.onerror = () => preview?.classList.add('d-none');
            } else {
                preview?.classList.add('d-none');
            }
        });
    </script>
}
