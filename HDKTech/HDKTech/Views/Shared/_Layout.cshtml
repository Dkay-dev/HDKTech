
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HDKTech</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/product-card.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body style="background-color: #ffffff;">

    <!-- ╔════════════════════════════════════════════════════════════════╗ -->
    <!-- ║ HEADER: Logo | Nav | Category | Search | Auth | Cart         ║ -->
    <!-- ╚════════════════════════════════════════════════════════════════╝ -->
<header class="hdk-tier1-header sticky-top" style="background-color: #000000; min-height: 64px; z-index: 1030;">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between px-4" style="gap: 1.5rem; width: 100%;">

            <!-- LEFT: Logo + Nav -->
            <div class="d-flex align-items-center" style="gap: 1.5rem; flex-shrink: 0;">
                <a href="/" class="text-decoration-none d-flex align-items-center">
                    <div class="hdk-logo">
                        <span class="hdk-logo-hdk">HDK</span><span class="hdk-logo-tech">Tech</span>
                    </div>
                </a>

                <div class="hdk-nav-links d-none d-xl-flex gap-3 align-items-center">
                    <a asp-area="" asp-controller="Home" asp-action="About" title="Về chúng tôi" class="nav-link-item">Về chúng tôi</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" title="Chính sách" class="nav-link-item">Chính sách</a>
                    <a asp-area="" asp-controller="Home" asp-action="Hotline" title="Liên hệ" class="nav-link-item">Liên hệ</a>
                </div>
            </div>

            <!-- CENTER: Search Bar + Category -->
            <div class="d-flex align-items-center" style="flex-grow: 1; max-width: 480px; gap: 8px;">
                <form asp-area="" asp-controller="Product" asp-action="Search" method="get" class="flex-grow-1">
                    <div class="hdk-search-container" style="height: 34px; background-color: #1A1A1A; border: 1px solid #2A2A2A;">
                        <input type="text"
                               class="hdk-search-input"
                               name="keyword"
                               placeholder="Tìm sản phẩm..."
                               aria-label="Tìm kiếm"
                               style="background-color: #1A1A1A; color: #fff;">
                        <button type="submit" class="hdk-search-btn" style="background-color: #E8002D; color: #fff; border: none;">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Category Dropdown - After Search -->
                <div class="dropdown d-none d-lg-block" style="flex-shrink: 0;">
                    <button class="hdk-category-btn dropdown-toggle" type="button" id="categoryDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="height: 34px; background-color: #E8002D; color: #fff; border: none;">
                        <i class="bi bi-list"></i>
                        <span class="d-none d-md-inline">Danh mục</span>
                    </button>
                    <div class="dropdown-menu hdk-dropdown-menu" aria-labelledby="categoryDropdown">
                        @await Component.InvokeAsync("Categories")
                    </div>
                </div>
            </div>

            <!-- RIGHT: Auth + Cart + Mobile Toggle -->
            <div class="d-flex align-items-center" style="gap: 1rem; flex-shrink: 0;">
                <div class="hdk-auth-links d-none d-lg-flex gap-0 align-items-center">
                    <partial name="_LoginPartial" />
                </div>

                <a asp-area="" asp-controller="Cart" asp-action="Index" class="hdk-cart-container d-inline-flex align-items-center justify-content-center position-relative" style="width: 36px; height: 36px;">
                    <i class="bi bi-bag-fill hdk-cart-icon"></i>
                    @await Component.InvokeAsync("CartSummary")
                </a>

                <button class="btn btn-link d-lg-none text-white p-0" type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu" aria-expanded="false">
                    <i class="bi bi-list fs-5"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div class="collapse d-lg-none" id="mobileMenu" style="background-color: #0D0D0D;">
            <div class="pb-3 px-3" style="border-top: 1px solid #2A2A2A;">
                <a asp-area="" asp-controller="Home" asp-action="About" class="d-block text-white text-decoration-none py-2">Về chúng tôi</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="d-block text-white text-decoration-none py-2">Chính sách</a>
                <a asp-area="" asp-controller="Home" asp-action="Hotline" class="d-block text-white text-decoration-none py-2">Liên hệ</a>
            </div>
        </div>
    </header>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- Toast Container (Notifications) -->
    <!-- ══════════════════════════════════════════════════════════���═��════ -->
    <div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1040;"></div>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- MAIN CONTENT AREA -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <main class="content-wrapper" style="margin-top: 0; padding: 0;">
        <div class="container-fluid" style="padding: 0;">
            <div class="row" style="margin: 0;">
                <div class="col-12" style="padding: 0;">
                    @RenderBody()
                </div>
            </div>
        </div>
    </main>

    <!-- ═════════════════════════════════════════════════════════════════════════ -->
    <!-- FOOTER - PROFESSIONAL DARK DESIGN -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <footer class="hdk-footer-pro">
        <style>
            :root {
                --hdk-red: #ef4444;
                --hdk-dark: #212529;
                --hdk-footer-bg: #000000;
                --hdk-footer-text: #e5e7eb;
            }

            .hdk-footer-pro {
                background: #050505;
                color: var(--hdk-footer-text);
                padding: 48px 0 20px;
                margin-top: 60px;
                border-top: 1px solid rgba(255, 255, 255, 0.08);
            }

            .footer-content {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 40px;
                margin-bottom: 40px;
            }

            .footer-brand {
                display: flex;
                flex-direction: column;
                gap: 14px;
            }

            .footer-brand-logo {
                display: flex;
                align-items: center;
                gap: 6px;
                font-size: 1.3rem;
                font-weight: 700;
                margin-bottom: 6px;
            }

                .footer-brand-logo span:first-child {
                    color: white;
                }

                .footer-brand-logo span:last-child {
                    color: var(--hdk-red);
                }

            .footer-brand-bio {
                font-size: 0.85rem;
                line-height: 1.6;
                color: rgba(255, 255, 255, 0.5);
            }

            .footer-social-icons {
                display: flex;
                gap: 10px;
                margin-top: 10px;
            }

            .footer-social-link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 40px;
                height: 40px;
                border-radius: 4px;
                background: #111111;
                color: white;
                text-decoration: none;
                transition: all 0.2s ease;
                font-size: 1rem;
                border: 1px solid rgba(255, 255, 255, 0.1);
            }

                .footer-social-link:hover {
                    background: var(--hdk-red);
                    border-color: var(--hdk-red);
                    transform: translateY(-2px);
                }

            .footer-column h5 {
                font-size: 0.85rem;
                font-weight: 700;
                color: white;
                margin-bottom: 16px;
                padding-bottom: 10px;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .footer-column-link {
                display: block;
                color: rgba(255, 255, 255, 0.5);
                text-decoration: none;
                padding: 8px 0;
                transition: all 0.2s ease;
                font-size: 0.85rem;
            }

                .footer-column-link:hover {
                    color: var(--hdk-red);
                    padding-left: 6px;
                }

            .footer-contact-item {
                display: flex;
                align-items: flex-start;
                gap: 12px;
                margin-bottom: 12px;
                padding: 10px;
                background: rgba(255, 255, 255, 0.02);
                border-radius: 4px;
                transition: all 0.2s ease;
            }

                .footer-contact-item:hover {
                    background: rgba(239, 68, 68, 0.08);
                    border-left: 2px solid var(--hdk-red);
                    padding-left: 10px;
                }

            .footer-contact-icon {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 28px;
                height: 28px;
                min-width: 28px;
                background: #ef4444;
                color: white;
                border-radius: 4px;
                font-size: 0.8rem;
            }

            .footer-contact-info {
                display: flex;
                flex-direction: column;
                gap: 2px;
            }

            .footer-contact-label {
                font-size: 0.7rem;
                color: rgba(255, 255, 255, 0.4);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                font-weight: 600;
            }

            .footer-contact-value {
                font-size: 0.85rem;
                color: var(--hdk-footer-text);
                word-break: break-word;
                line-height: 1.4;
            }

                .footer-contact-value a {
                    color: var(--hdk-red);
                    text-decoration: none;
                    transition: color 0.2s ease;
                }

                    .footer-contact-value a:hover {
                        text-decoration: underline;
                    }

            .footer-bottom {
                border-top: 1px solid rgba(255, 255, 255, 0.08);
                padding-top: 20px;
                display: flex;
                flex-direction: column;
                gap: 8px;
                align-items: center;
                justify-content: center;
                text-align: center;
            }

            .footer-copyright {
                font-size: 0.8rem;
                color: rgba(255, 255, 255, 0.4);
            }

                .footer-copyright a {
                    color: var(--hdk-red);
                    text-decoration: none;
                    transition: color 0.2s ease;
                }

                    .footer-copyright a:hover {
                        color: #dc2626;
                    }

            .footer-credit {
                font-size: 0.75rem;
                color: rgba(255, 255, 255, 0.25);
            }

            @@media (max-width: 1199px) {
                .footer-content {
                    grid-template-columns: repeat(2, 1fr);
                    gap: 30px;
                }
            }

            @@media (max-width: 991px) {
                .hdk-footer-pro {
                    padding: 36px 0 16px;
                    margin-top: 50px;
                }

                .footer-content {
                    grid-template-columns: repeat(2, 1fr);
                    gap: 24px;
                }

                .footer-social-icons {
                    justify-content: flex-start;
                }
            }

            @@media (max-width: 576px) {
                .hdk-footer-pro {
                    padding: 28px 0 16px;
                    margin-top: 30px;
                }

                .footer-content {
                    grid-template-columns: 1fr;
                    gap: 24px;
                }

                .footer-brand-bio {
                    max-width: 100%;
                }

                .footer-column h5 {
                    font-size: 0.85rem;
                    margin-bottom: 12px;
                }

                .footer-bottom {
                    gap: 6px;
                }

                .footer-copyright,
                .footer-credit {
                    font-size: 0.75rem;
                }
            }
        </style>

        <div class="container">
            <div class="footer-content">
                <!-- Column 1: Brand & Social -->
                <div class="footer-brand">
                    <div class="footer-brand-logo">
                        <span>HDK</span><span>Tech</span>
                    </div>
                    <p class="footer-brand-bio">
                        Chuyên cung cấp laptop, linh kiện máy tính chính hãng với giá tốt nhất thị trường.
                    </p>
                    <div class="footer-social-icons">
                        <a href="https://www.facebook.com/hdktech" target="_blank" rel="noopener" title="Facebook" class="footer-social-link">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="https://www.instagram.com/hdktech" target="_blank" rel="noopener" title="Instagram" class="footer-social-link">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="https://www.youtube.com/hdktech" target="_blank" rel="noopener" title="YouTube" class="footer-social-link">
                            <i class="bi bi-youtube"></i>
                        </a>
                        <a href="https://zalo.me/0901234567" target="_blank" rel="noopener" title="Zalo" class="footer-social-link">
                            <i class="bi bi-chat-dots"></i>
                        </a>
                    </div>
                </div>

                <!-- Column 2: About -->
                <div class="footer-column footer-about">
                    <h5>Về chúng tôi</h5>
                    <a asp-area="" asp-controller="Home" asp-action="About" class="footer-column-link">Giới thiệu công ty</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-column-link">Tin tức</a>
                    <a href="#" class="footer-column-link">Tuyển dụng</a>
                    <a asp-area="" asp-controller="Home" asp-action="Hotline" class="footer-column-link">Liên hệ</a>
                </div>

                <!-- Column 3: Support -->
                <div class="footer-column footer-support">
                    <h5>Hỗ trợ khách hàng</h5>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-column-link">Chính sách bảo hành</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-column-link">Chính sách đổi trả</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-column-link">Hướng dẫn mua hàng</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-column-link">Phương thức thanh toán</a>
                </div>

                <!-- Column 4: Contact Info -->
                <div class="footer-column footer-contact">
                    <h5>Liên hệ</h5>
                    <div class="footer-contact-item">
                        <div class="footer-contact-icon">
                            <i class="bi bi-geo-alt"></i>
                        </div>
                        <div class="footer-contact-info">
                            <span class="footer-contact-label">Địa chỉ</span>
                            <span class="footer-contact-value">123 Đường ABC, Quận 1, TP.HCM</span>
                        </div>
                    </div>
                    <div class="footer-contact-item">
                        <div class="footer-contact-icon">
                            <i class="bi bi-telephone"></i>
                        </div>
                        <div class="footer-contact-info">
                            <span class="footer-contact-label">Hotline</span>
                            <span class="footer-contact-value"><a href="tel:1900123456">1900.123.456</a></span>
                        </div>
                    </div>
                    <div class="footer-contact-item">
                        <div class="footer-contact-icon">
                            <i class="bi bi-envelope"></i>
                        </div>
                        <div class="footer-contact-info">
                            <span class="footer-contact-label">Email</span>
                            <span class="footer-contact-value"><a href="mailto:support@hdktech.vn">support@hdktech.vn</a></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bottom Footer -->
            <div class="footer-bottom">
                <p class="footer-copyright">
                    &copy; 2026 <a asp-area="" asp-controller="Home" asp-action="Index">HDKTech</a>. Tất cả các quyền được bảo lưu.
                </p>
                <p class="footer-credit">
                    Powered by HDKTech | Thiết kế &amp; Phát triển bởi <a href="#" style="color: var(--hdk-red); text-decoration: none;">HDKTech Team</a>
                </p>
            </div>
        </div>
    </footer>

    <!-- ═════════════════════════════════════════════════════════════════ -->
    <!-- JavaScript Libraries -->
    <!-- ═════════════════════════════════════════════════════════════════ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        /* Hide progress bar & scrollbar */
        #nprogress, #nprogress .bar, #nprogress .peg, #nprogress .spinner {
            display: none !important;
        }

        .progress, .progress-bar {
            display: none !important;
        }

        body::-webkit-scrollbar {
            display: none;
        }

        body {
            scrollbar-width: none;
            -ms-overflow-style: none;
        }
    </style>
    <script src="~/js/image-fallback.js"></script>
    <script src="~/js/cart.js"></script>

    <!-- Admin Sidebar Toggle Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebarClose = document.getElementById('sidebarClose');
            const adminSidebar = document.getElementById('adminSidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');

            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    adminSidebar.classList.toggle('active');
                    sidebarOverlay.classList.toggle('active');
                });
            }

            if (sidebarClose) {
                sidebarClose.addEventListener('click', function(e) {
                    e.preventDefault();
                    adminSidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }

            if (sidebarOverlay) {
                sidebarOverlay.addEventListener('click', function() {
                    adminSidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }

            const sidebarItems = document.querySelectorAll('.hdk-sidebar-item');
            sidebarItems.forEach(item => {
                item.addEventListener('click', function() {
                    adminSidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>